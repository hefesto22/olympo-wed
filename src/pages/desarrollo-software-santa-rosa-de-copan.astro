---
import Layout from '../layouts/Layout.astro';

const services = [
  { icon: '💻', title: 'Software a Medida', desc: 'Sistemas POS, ERP y CRM diseñados para la realidad de negocios en Santa Rosa de Copán. Facturación, inventario y reportes en tiempo real.' },
  { icon: '📱', title: 'Apps Móviles', desc: 'Aplicaciones iOS y Android para conectar con tus clientes en Copán. Pedidos en línea, delivery, fidelización y más.' },
  { icon: '🔗', title: 'APIs e Integraciones', desc: 'Conectamos tus sistemas actuales con pasarelas de pago, facturación electrónica y plataformas que usas todos los días.' },
  { icon: '⚡', title: 'Automatizaciones', desc: 'Automatizamos procesos repetitivos con N8N y Make. Reportes, notificaciones, sincronización de datos — todo sin trabajo manual.' },
  { icon: '🛡️', title: 'Infraestructura', desc: 'Servidores seguros, backups automáticos, SSL y monitoreo 24/7. Tu sistema siempre disponible para tus clientes.' },
  { icon: '🧭', title: 'Consultoría IT', desc: 'Te ayudamos a tomar las decisiones tecnológicas correctas antes de invertir. Auditoría, roadmap y acompañamiento técnico.' },
];

const faqs = [
  {
    question: '¿Hay una empresa de desarrollo de software en Santa Rosa de Copán?',
    answer: 'Sí. Olympo Code es una empresa de desarrollo de software con sede en Santa Rosa de Copán, Copán, Honduras. Desarrollamos software a medida, apps móviles, sistemas POS, ERP, CRM, automatizaciones e infraestructura cloud para empresas locales y nacionales.'
  },
  {
    question: '¿Qué tipos de software pueden desarrollar para mi negocio en Santa Rosa?',
    answer: 'Desarrollamos sistemas POS para puntos de venta, ERP para gestión empresarial, CRM para manejo de clientes, aplicaciones móviles, APIs e integraciones con pasarelas de pago, y automatizaciones de procesos. Todo personalizado para tu negocio.'
  },
  {
    question: '¿Cuánto cuesta un sistema POS o software a medida en Copán?',
    answer: 'El costo varía según las funcionalidades que necesites. Ofrecemos una consulta inicial gratuita donde analizamos tu caso y te entregamos una cotización clara sin compromiso. Trabajamos con presupuestos desde $1,000 USD según la complejidad.'
  },
  {
    question: '¿Olympo Code trabaja solo en Santa Rosa de Copán?',
    answer: 'Nuestra oficina está en Santa Rosa de Copán pero trabajamos con clientes en todo el departamento de Copán, Honduras y Centroamérica. Ofrecemos reuniones presenciales en la zona y virtuales para clientes fuera de la ciudad.'
  },
];
---

<Layout
  title="Desarrollo de Software en Santa Rosa de Copán | Olympo Code"
  description="Empresa de desarrollo de software en Santa Rosa de Copán, Copán. Sistemas POS, ERP, CRM, apps móviles, automatizaciones e infraestructura cloud. Primera consulta gratis."
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Desarrollo de Software en Santa Rosa de Copán', url: '/desarrollo-software-santa-rosa-de-copan' },
  ]}
  faq={faqs}
>

<div class="geo-page">
  <div class="container">

    <!-- Hero -->
    <div class="geo-hero">
      <p class="label-tag">Santa Rosa de Copán, Copán</p>
      <h1 class="geo-title">
        Desarrollo de Software<br/>
        <span class="geo-em">en Santa Rosa de Copán</span>
      </h1>
      <p class="geo-lead">
        Somos Olympo Code — empresa de tecnología con sede en Santa Rosa de Copán.
        Diseñamos y construimos software a medida, apps móviles, sistemas POS, ERP y CRM
        para negocios locales y empresas en todo Honduras.
      </p>
      <div class="geo-actions">
        <a href="/contacto" class="btn btn-primary">Solicitar consulta gratis</a>
        <a href="/servicios" class="btn btn-secondary">Ver servicios →</a>
      </div>
    </div>

    <!-- Servicios -->
    <section class="geo-services">
      <h2 class="geo-section-title">Servicios de software para empresas en Santa Rosa de Copán</h2>
      <div class="geo-grid">
        {services.map(s => (
          <div class="geo-card">
            <span class="geo-card-icon">{s.icon}</span>
            <h3 class="geo-card-title">{s.title}</h3>
            <p class="geo-card-desc">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Por qué local -->
    <section class="geo-why">
      <h2 class="geo-section-title">¿Por qué elegir una empresa de software local?</h2>
      <div class="geo-why-grid">
        <div class="geo-why-item">
          <h3>Reuniones presenciales</h3>
          <p>Estamos en Santa Rosa de Copán. Podemos reunirnos cara a cara para entender tu negocio y mostrarte avances en persona.</p>
        </div>
        <div class="geo-why-item">
          <h3>Conocemos el mercado local</h3>
          <p>Entendemos la realidad de los negocios en Copán — desde restaurantes y comercios hasta empresas de servicio y agroindustria.</p>
        </div>
        <div class="geo-why-item">
          <h3>Soporte rápido y cercano</h3>
          <p>Si algo falla, no tenés que esperar a que alguien de otra ciudad te responda. Estamos aquí, a una llamada o visita de distancia.</p>
        </div>
        <div class="geo-why-item">
          <h3>Precios competitivos</h3>
          <p>Al estar basados en Honduras, ofrecemos calidad internacional a precios accesibles para el mercado centroamericano.</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="geo-faq">
      <h2 class="geo-section-title">Preguntas frecuentes</h2>
      <div class="geo-faq-list">
        {faqs.map(f => (
          <details class="geo-faq-item">
            <summary class="geo-faq-q">{f.question}</summary>
            <p class="geo-faq-a">{f.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="geo-cta">
      <h2 class="geo-cta-title">¿Listo para construir tu próximo proyecto?</h2>
      <p class="geo-cta-desc">Primera consulta sin costo y sin compromiso. Cuéntanos qué necesitas y te respondemos con un plan claro.</p>
      <div class="geo-actions">
        <a href="/contacto" class="btn btn-primary">Iniciar proyecto</a>
        <a href="https://wa.me/50433012826" class="btn btn-whatsapp" target="_blank" rel="noopener nofollow">WhatsApp →</a>
      </div>
    </section>

  </div>
</div>

</Layout>

<style>
  .geo-page { padding: 5rem 0 7rem; }

  .geo-hero {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .geo-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.08;
    color: var(--text-1);
  }

  .geo-em {
    background: linear-gradient(115deg, #f0d080, #c8a040 40%, #e8b860 70%, #9a6a28);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .geo-lead {
    font-size: 0.95rem;
    color: var(--text-2);
    line-height: 1.75;
    font-weight: 300;
    max-width: 560px;
  }

  .geo-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .geo-section-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-1);
    text-align: center;
    margin-bottom: 2.5rem;
  }

  /* Services grid */
  .geo-services { margin-bottom: 5rem; }
  .geo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .geo-card {
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.75rem;
    background: var(--bg-1);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .geo-card:hover {
    border-color: var(--border-gold);
    transform: translateY(-2px);
  }

  .geo-card-icon { font-size: 1.5rem; display: block; margin-bottom: 0.75rem; }
  .geo-card-title { font-size: 1rem; font-weight: 600; color: var(--text-1); margin-bottom: 0.5rem; }
  .geo-card-desc { font-size: 0.82rem; color: var(--text-2); line-height: 1.7; font-weight: 300; }

  /* Why section */
  .geo-why { margin-bottom: 5rem; }
  .geo-why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }
  .geo-why-item { padding: 1.5rem; border-left: 2px solid var(--gold); }
  .geo-why-item h3 { font-size: 0.9rem; font-weight: 600; color: var(--text-1); margin-bottom: 0.5rem; }
  .geo-why-item p { font-size: 0.82rem; color: var(--text-2); line-height: 1.7; font-weight: 300; }

  /* FAQ */
  .geo-faq { margin-bottom: 5rem; max-width: 720px; margin-left: auto; margin-right: auto; }
  .geo-faq-list { display: flex; flex-direction: column; gap: 0; }

  .geo-faq-item {
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 0;
  }

  .geo-faq-q {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-1);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .geo-faq-q::-webkit-details-marker { display: none; }
  .geo-faq-q::after {
    content: '+';
    font-size: 1.2rem;
    color: var(--text-3);
    transition: transform 0.2s ease;
    flex-shrink: 0;
    margin-left: 1rem;
  }
  details[open] .geo-faq-q::after { content: '−'; }

  .geo-faq-a {
    font-size: 0.82rem;
    color: var(--text-2);
    line-height: 1.75;
    font-weight: 300;
    margin-top: 0.75rem;
    padding-right: 2rem;
  }

  /* CTA */
  .geo-cta {
    text-align: center;
    padding: 3rem;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--bg-1);
  }
  .geo-cta-title { font-size: 1.5rem; font-weight: 700; color: var(--text-1); margin-bottom: 0.75rem; letter-spacing: -0.02em; }
  .geo-cta-desc { font-size: 0.85rem; color: var(--text-2); line-height: 1.7; font-weight: 300; margin-bottom: 1.5rem; max-width: 450px; margin-left: auto; margin-right: auto; }
</style>
