---
// src/pages/servicios.astro
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id:       'software-medida',
    num:      '01',
    title:    'Software a Medida',
    tagline:  'Construido para cómo operas hoy. Diseñado para lo que serás mañana.',
    desc1:    'No creemos en el software que obliga a tu empresa a adaptarse a él. Creemos en el software que se construye entendiendo primero cómo funciona tu negocio — sus procesos reales, sus cuellos de botella y sus metas a futuro.',
    desc2:    'Cada sistema que entregamos está pensado para resolver el problema de hoy sin cerrarte las puertas del mañana. Arquitectura limpia, código escalable y documentación completa para que puedas crecer sin reconstruir desde cero.',
    includes: ['Diagnóstico profundo de tus procesos','Sistemas POS, ERP y CRM a tu medida','Paneles con datos en tiempo real','Módulos que crecen con tu negocio','Facturación, reportes e inventario','Integración con tus herramientas actuales'],
    tech:     ['Laravel', 'React', 'Node.js', 'PostgreSQL', 'Docker', 'Redis'],
    stats:    [['Plazo típico', '6–12 semanas'], ['Avance', 'demo cada 2 semanas'], ['Código', '100% tuyo']],
    steps:    ['Diagnóstico de procesos', 'Propuesta y alcance', 'Sprints con demos', 'Entrega + capacitación'],
    color:    '#c8a96e',
    icon:     '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="4" stroke="currentColor" stroke-width="1.5"/><path d="M8 16l-3-3 3-3M16 8l3 3-3 3M14 6l-4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  },
  {
    id:       'apps-moviles',
    num:      '02',
    title:    'Apps Móviles',
    tagline:  'La app que tu cliente necesita. No la que es más fácil de hacer.',
    desc1:    'Una app mediocre puede dañar más tu marca que no tener una. Por eso antes de escribir código, entendemos a quién va dirigida, cómo la va a usar y qué problema real va a resolver en su día a día.',
    desc2:    'Construimos aplicaciones que se sienten rápidas, intuitivas y confiables — desde la primera pantalla hasta la última actualización. Y cuando tu negocio crezca, la app crece con él.',
    includes: ['Análisis de usuario y diseño UX','Apps nativas iOS y Android','React Native y Flutter multiplataforma','Integración con APIs y pagos','Publicación en App Store y Google Play','Soporte y evolución continua'],
    tech:     ['React Native', 'Flutter', 'Swift', 'Kotlin', 'Firebase', 'Expo'],
    stats:    [['Plazo típico', '8–14 semanas'], ['Plataformas', 'iOS + Android'], ['Publicación', 'incluida']],
    steps:    ['UX research y prototipo', 'Diseño de interfaz', 'Desarrollo iterativo', 'Publicación en stores'],
    color:    '#ff3d71',
    icon:     '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="7" y="2" width="10" height="20" rx="2.5" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="18" r="1" fill="currentColor"/><path d="M10 5h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>',
  },
  {
    id:       'apis-integraciones',
    num:      '03',
    title:    'APIs e Integraciones',
    tagline:  'Tus sistemas conectados. Tu operación sin fricciones.',
    desc1:    'Cada sistema aislado es tiempo perdido y errores esperando ocurrir. Diseñamos integraciones que conectan tus herramientas en flujos de datos confiables y auditables — sin importar qué tan viejos sean los sistemas.',
    desc2:    'Lo que construimos hoy se conecta con lo que necesites mañana. Arquitectura de APIs que crece con tu operación y no se convierte en un problema cuando escales.',
    includes: ['APIs RESTful y GraphQL','Pasarelas de pago locales e internacionales','Integración con ERPs y CRMs','Webhooks y eventos en tiempo real','Autenticación segura OAuth 2.0','Documentación técnica completa'],
    tech:     ['REST', 'GraphQL', 'Webhooks', 'OAuth 2.0', 'Node.js', 'Laravel'],
    stats:    [['Plazo típico', '2–6 semanas'], ['Uptime objetivo', '99.9%'], ['Documentación', 'incluida']],
    steps:    ['Mapeo de sistemas', 'Diseño de contratos', 'Implementación y pruebas', 'Docs + monitoreo'],
    color:    '#00d2ff',
    icon:     '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="4" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="5" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="19" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M7 12h6m0 0V7.5M13 12v4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>',
  },
  {
    id:       'automatizaciones',
    num:      '04',
    title:    'Automatizaciones N8N',
    tagline:  'Menos tareas manuales. Más tiempo para lo que importa.',
    desc1:    'Si tu equipo dedica horas a copiar datos entre sistemas o generar reportes a mano — eso no es trabajo, es desperdicio. Lo automatizamos para que tu gente se enfoque en lo que realmente genera valor.',
    desc2:    'No automatizamos por automatizar — identificamos qué tareas tienen el mayor impacto y empezamos por ahí. Flujos que se adaptan a tu realidad hoy y se amplían cuando tu operación lo exija.',
    includes: ['Mapeo de procesos a automatizar','Flujos de notificaciones y alertas','Sincronización entre plataformas','Reportes ejecutivos automáticos','Conexión con Slack, Gmail, Sheets y más','Monitoreo y mantenimiento continuo'],
    tech:     ['N8N', 'Make', 'Zapier', 'Python', 'Node.js', 'Cron Jobs'],
    stats:    [['Plazo típico', '1–3 semanas'], ['Ahorro típico', '40+ h/mes'], ['Monitoreo', 'incluido']],
    steps:    ['Mapeo de tareas', 'Priorización por impacto', 'Construcción de flujos', 'Monitoreo continuo'],
    color:    '#ff9500',
    icon:     '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 12a8 8 0 0 1 8-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M20 12a8 8 0 0 1-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M12 4l2.5 2.5L12 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 20l-2.5-2.5L12 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  },
  {
    id:       'infraestructura',
    num:      '05',
    title:    'Infraestructura',
    tagline:  'La base que tu sistema necesita para no fallar nunca.',
    desc1:    'El mejor software del mundo es inútil si el servidor cae en el momento equivocado. Configuramos y mantenemos infraestructura robusta con seguridad, monitoreo y respaldo como prioridades.',
    desc2:    'No solo dejamos todo funcionando el día del lanzamiento. Nos quedamos monitoreando, actualizando y ajustando para que tu operación esté disponible cuando tus clientes la necesiten.',
    includes: ['Servidores VPS, cloud y dedicados','Docker y containerización','SSL, firewalls y hardening','CI/CD para deploys sin riesgo','Monitoreo 24/7 y backups automáticos','Escalabilidad planificada'],
    tech:     ['Linux', 'Docker', 'Nginx', 'GitHub Actions', 'Cloudflare', 'VPS'],
    stats:    [['Setup inicial', '1–2 semanas'], ['Uptime', '99.9%+'], ['Backups', 'diarios automáticos']],
    steps:    ['Auditoría del entorno', 'Arquitectura y plan', 'Migración sin downtime', 'Monitoreo 24/7'],
    color:    '#00e676',
    icon:     '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="2" y="14" width="20" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/><circle cx="18.5" cy="7" r="1" fill="currentColor"/><circle cx="15.5" cy="7" r="1" fill="currentColor"/><circle cx="18.5" cy="17" r="1" fill="currentColor"/><circle cx="15.5" cy="17" r="1" fill="currentColor"/></svg>',
  },
  {
    id:       'consultoria',
    num:      '06',
    title:    'Consultoría IT',
    tagline:  'Las decisiones técnicas correctas en el momento correcto.',
    desc1:    'Tomar la decisión tecnológica equivocada hoy puede costarte meses y miles de dólares mañana. Antes de construir cualquier cosa, necesitas entender qué construir, en qué orden y con qué tecnología.',
    desc2:    'No venimos con una solución predefinida. Analizamos tu situación real, identificamos riesgos y oportunidades, y diseñamos un camino técnico que tenga sentido para tu negocio ahora y en los próximos años.',
    includes: ['Auditoría de sistemas y arquitectura','Identificación de deudas técnicas','Roadmap priorizado por impacto','Evaluación de tecnologías y proveedores','Revisión de código','Acompañamiento en decisiones críticas'],
    tech:     ['Arquitectura', 'Code Review', 'Roadmap', 'UML', 'SQL', 'DevOps'],
    stats:    [['Plazo típico', '2–4 semanas'], ['Entregable', 'roadmap accionable'], ['Formato', 'remoto o presencial']],
    steps:    ['Auditoría técnica', 'Hallazgos y riesgos', 'Roadmap priorizado', 'Acompañamiento'],
    color:    '#d946ef',
    icon:     '<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M12 7v5.5l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  },
];
---

<Layout
  title="Servicios de Desarrollo de Software en Honduras | POS, ERP, Apps Móviles"
  description="Desarrollo de software a medida, apps móviles, APIs, automatizaciones N8N, infraestructura cloud y consultoría IT en Santa Rosa de Copán, Copán. Soluciones tecnológicas para empresas hondureñas."
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Servicios', url: '/servicios' },
  ]}
>

<div class="svc-page">

  <!-- ── HERO centrado ── -->
  <div class="svc-hero">
    <div class="container">
      <div class="svc-hero-inner">
        <p class="label-tag">Servicios</p>
        <h1 class="svc-hero-title">Todo lo que necesitas<br/><span class="svc-hero-em">en un solo equipo.</span></h1>
        <p class="svc-hero-sub">Desde la idea hasta el servidor — construimos, integramos, automatizamos y mantenemos sin depender de terceros.</p>
      </div>
    </div>
  </div>

  <!-- ── TABS centrados, sin números ── -->
  <div class="svc-tabs-wrap">
    <div class="container">
      <div class="svc-tabs" role="tablist">
        {services.map((s, i) => (
          <button
            class={`svc-tab ${i === 0 ? 'active' : ''}`}
            role="tab"
            data-index={i}
            aria-selected={i === 0 ? 'true' : 'false'}
            style={`--svc-color: ${s.color}`}
          >
            <span class="svc-tab-icon" set:html={s.icon} />
            <span class="svc-tab-name">{s.title}</span>
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- ── PANELS ── -->
  <div class="container">
    <div class="svc-panels">
      {services.map((s, i) => (
        <div
          class={`svc-panel ${i === 0 ? 'active' : ''}`}
          role="tabpanel"
          data-index={i}
          data-id={s.id}
          id={s.id}
          style={`--svc-color: ${s.color}`}
        >
          <div class="panel-header">
            <span class="panel-num" aria-hidden="true">{s.num}</span>
            <div class="panel-icon" set:html={s.icon} />
            <div class="panel-title-group">
              <h2 class="panel-title">{s.title}</h2>
              <p class="panel-tagline">{s.tagline}</p>
            </div>
            <a href="/contacto" class="panel-cta">
              Cotizar este servicio
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>

          <div class="panel-stats">
            {s.stats.map(([l, v]) => (
              <div class="pstat">
                <span class="pstat-l">{l}</span>
                <span class="pstat-v">{v}</span>
              </div>
            ))}
          </div>

          <div class="panel-body">
            <div class="panel-desc">
              <p class="panel-desc-p">{s.desc1}</p>
              <p class="panel-desc-p">{s.desc2}</p>
              <div class="panel-tech">
                {s.tech.map(t => <span class="panel-chip">{t}</span>)}
              </div>
            </div>
            <div class="panel-includes">
              <p class="panel-includes-title">Qué incluye este servicio</p>
              <ul class="panel-includes-list">
                {s.includes.map((item, idx) => (
                  <li class="panel-include-item" style={`animation-delay: ${idx * 60}ms`}>
                    <div class="include-check">
                      <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                        <path d="M2 5l2.5 2.5L8 2.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="panel-process">
            <p class="process-title">Cómo trabajamos</p>
            <div class="process-steps">
              {s.steps.map((st, idx) => (
                <div class="pstep">
                  <div class="pstep-top">
                    <span class="pstep-num">{idx + 1}</span>
                    {idx < s.steps.length - 1 && <span class="pstep-line"></span>}
                  </div>
                  <span class="pstep-name">{st}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="panel-footer">
            <div class="pf-copy">
              <p class="pf-title">¿Suena a lo que tu negocio necesita?</p>
              <p class="pf-sub">Primera consulta gratuita — analizamos tu caso y te damos una cotización clara, sin compromiso.</p>
            </div>
            <div class="pf-actions">
              <a href="/contacto" class="pf-btn-main">Cotización gratuita</a>
              <a href="https://wa.me/50433012826" target="_blank" rel="noopener nofollow" class="pf-btn-wa">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                WhatsApp
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

</div>

</Layout>

<style>
  .svc-page {
    padding-bottom: 7rem;
    min-height: 100vh;
  }

  /* ── Hero centrado ── */
  .svc-hero {
    padding: 5rem 0 3rem;
  }

  .svc-hero-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .svc-hero-title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--text-1);
    margin: 0.65rem 0 1rem;
  }

  .svc-hero-em {
    background: linear-gradient(115deg, #f0d080 0%, #c8a040 40%, #e8b860 70%, #9a6a28 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .svc-hero-sub {
    font-size: 0.95rem;
    color: var(--text-2);
    font-weight: 300;
    line-height: 1.7;
    max-width: 520px;
  }

  /* ── Tabs centrados ── */
  .svc-tabs-wrap {
    position: sticky;
    top: 56px;
    z-index: 50;
    background: rgba(8,8,8,0.88);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .svc-tabs {
    display: flex;
    overflow-x: auto;
    scrollbar-width: none;
    justify-content: center;
  }
  .svc-tabs::-webkit-scrollbar { display: none; }

  .svc-tab {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0.85rem 1.35rem;
    border: none;
    background: none;
    cursor: pointer;
    flex-shrink: 0;
    position: relative;
    transition: all 0.2s ease;
    color: var(--text-3);
    min-width: 90px;
  }

  .svc-tab::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--svc-color);
    transform: scaleX(0);
    transition: transform 0.25s ease;
    border-radius: 2px 2px 0 0;
  }
  .svc-tab.active::after  { transform: scaleX(1); }
  .svc-tab.active         { color: var(--text-1); }
  .svc-tab:hover:not(.active) { color: var(--text-2); background: rgba(255,255,255,0.02); }

  .svc-tab-icon {
    width: 20px; height: 20px;
    display: flex; align-items: center; justify-content: center;
  }
  .svc-tab-icon svg { width: 18px; height: 18px; }

  .svc-tab-name {
    font-size: 0.62rem;
    font-weight: 500;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  @media (max-width: 600px) {
    .svc-tab-name  { display: none; }
    .svc-tab       { min-width: 52px; padding: 0.75rem; }
  }

  /* ── Panels ── */
  .svc-panels { position: relative; }

  .svc-panel {
    display: none;
    animation: panel-in 0.35s ease forwards;
  }
  .svc-panel.active { display: block; }

  @keyframes panel-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .panel-header {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: 16px 16px 0 0;
    background: var(--bg-1);
    position: relative;
    overflow: hidden;
  }
  .panel-header::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--svc-color);
  }
  .panel-header::after {
    content: '';
    position: absolute;
    top: -40px; right: -40px;
    width: 200px; height: 200px;
    background: radial-gradient(circle, var(--svc-color), transparent 70%);
    opacity: 0.06;
    pointer-events: none;
  }

  .panel-num {
    position: absolute;
    top: 50%; right: 2rem;
    transform: translateY(-50%);
    font-size: 5.5rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.05em;
    color: var(--text-1);
    opacity: 0.05;
    pointer-events: none;
    user-select: none;
    font-variant-numeric: tabular-nums;
  }

  .panel-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
    align-self: center;
    flex-shrink: 0;
    padding: 0.6rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-2);
    text-decoration: none;
    position: relative;
    z-index: 1;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .panel-cta:hover {
    border-color: var(--svc-color);
    color: var(--text-1);
    background: color-mix(in srgb, var(--svc-color) 8%, transparent);
    transform: translateY(-1px);
  }
  @media (max-width: 768px) { .panel-cta { display: none; } }

  /* ── Stats strip ── */
  .panel-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--border);
    border-top: none;
    background: var(--bg-1);
  }
  .pstat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem 2rem;
    border-right: 1px solid var(--border);
  }
  .pstat:last-child { border-right: none; }
  .pstat-l {
    font-size: 0.56rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--text-3);
  }
  .pstat-v {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-1);
    letter-spacing: -0.01em;
  }
  @media (max-width: 600px) {
    .pstat { padding: 0.75rem 1rem; }
    .pstat-v { font-size: 0.72rem; }
  }

  .panel-icon {
    width: 56px; height: 56px;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--bg-3);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    color: var(--svc-color);
  }
  .panel-icon svg { width: 24px; height: 24px; }

  .panel-title {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 700;
    color: var(--text-1);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 0.4rem;
  }

  .panel-tagline {
    font-size: 0.9rem;
    color: var(--text-2);
    font-style: italic;
