<script>
const tabs   = document.querySelectorAll<HTMLButtonElement>('.svc-tab');
const panels = document.querySelectorAll<HTMLElement>('.svc-panel');

function activate(idx: string | number, updateHash = true) {
  tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
  const tab = document.querySelector<HTMLButtonElement>(`.svc-tab[data-index="${idx}"]`);
  if (!tab) return;
  tab.classList.add('active');
  tab.setAttribute('aria-selected', 'true');

  panels.forEach(p => p.classList.remove('active'));
  const panel = document.querySelector<HTMLElement>(`.svc-panel[data-index="${idx}"]`);
  panel?.classList.add('active');

  if (updateHash && panel?.dataset.id) {
    history.replaceState(null, '', `#${panel.dataset.id}`);
  }
  tab.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
}

tabs.forEach(tab => {
  tab.addEventListener('click', () => activate(tab.dataset.index!));
});

// Deep-link: /servicios#software-medida abre la pestaña correcta
function openFromHash() {
  const id = location.hash.slice(1);
  if (!id) return;
  const panel = document.querySelector<HTMLElement>(`.svc-panel[data-id="${id}"]`);
  if (panel?.dataset.index) activate(panel.dataset.index, false);
}
openFromHash();
window.addEventListener('hashchange', openFromHash);

document.addEventListener('keydown', (e) => {
  const activeTab = document.querySelector<HTMLButtonElement>('.svc-tab.active');
  if (!activeTab) return;
  const idx = parseInt(activeTab.dataset.index || '0');
  if (e.key === 'ArrowRight') document.querySelector<HTMLButtonElement>(`.svc-tab[data-index="${idx + 1}"]`)?.click();
  if (e.key === 'ArrowLeft')  document.querySelector<HTMLButtonElement>(`.svc-tab[data-index="${idx - 1}"]`)?.click();
});
</script>