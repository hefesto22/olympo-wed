---
// Landing de intención: "sistema punto de venta Honduras", "sistema POS Honduras"
import Layout from '../layouts/Layout.astro';

const negocios = [
  { icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l1.2-4.5h11.6L17 8"/><path d="M3 8c0 1.1.9 2 2 2s2-.9 2-2c0 1.1.9 2 2 2s2-.9 2-2c0 1.1.9 2 2 2s2-.9 2-2"/><path d="M4 10v6.5h12V10"/><path d="M8 16.5v-4h4v4"/></svg>', title: 'Tiendas y minisúper', desc: 'Ventas rápidas con lector de código de barras, control de inventario por producto y cierre de caja diario sin cuadrar a mano.' },
  { icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="14" height="14" rx="3.5"/><path d="M10 7v6M7 10h6"/></svg>', title: 'Farmacias', desc: 'Control de lotes y vencimientos, inventario en tiempo real y alertas de stock mínimo para que nunca falte un producto.' },
  { icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M10 2.8l6.2 3.6v7.2L10 17.2l-6.2-3.6V6.4L10 2.8z"/><circle cx="10" cy="10" r="2.6"/></svg>', title: 'Ferreterías y agroservicios', desc: 'Miles de productos, precios por mayoreo y detalle, cotizaciones e inventario multi-bodega bajo control.' },
  { icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7.5 3.5L3.5 6l1.8 2.8 1.7-1V16.5h6V7.8l1.7 1L16.5 6l-4-2.5c0 1.1-1.1 2-2.5 2s-2.5-.9-2.5-2z"/></svg>', title: 'Boutiques y tiendas de ropa', desc: 'Variantes por talla y color, apartados, promociones y reportes de lo que más se vende.' },
  { icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 3v4.5M4.5 3v4.5a2 2 0 004 0V3M6.5 9.5V17"/><path d="M13.5 3v14M13.5 3c1.8 0 2.8 1.8 2.8 4.5 0 2.4-1 3.8-2.8 3.8"/></svg>', title: 'Restaurantes y cafeterías', desc: 'Comandas a cocina, control de mesas y menú. Tenemos una solución especializada para comida.' },
  { icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M13.2 3a4 4 0 00-3.9 5L3.6 13.7a1.9 1.9 0 002.7 2.7L12 10.7a4 4 0 005-3.9l-2.4 2.4-2.8-2.8L14.2 4c-.3-.6-.6-.9-1-1z"/></svg>', title: 'Talleres y servicios', desc: 'Órdenes de trabajo, repuestos, facturación de servicios y seguimiento de cada cliente.' },
];

const features = [
  'Facturación adaptada a los requisitos fiscales de Honduras (SAR)',
  'Control de inventario en tiempo real con alertas de stock',
  'Ventas en efectivo, tarjeta y transferencia',
  'Cierre de caja automático por turno y por cajero',
  'Reportes de ventas diarios, semanales y mensuales',
  'Funciona en computadora, tablet o celular',
  'Sigue operando aunque se vaya el internet',
  'Múltiples sucursales y bodegas en un solo sistema',
];

const faqs = [
  {
    question: '¿Cuánto cuesta un sistema punto de venta en Honduras?',
    answer: 'Depende de lo que tu negocio necesite. Un POS a medida con Olympo Code comienza desde $1,000 USD e incluye facturación, inventario, reportes y capacitación. La primera consulta es gratuita: analizamos tu caso y te damos una cotización clara sin compromiso.'
  },
  {
    question: '¿El sistema funciona sin internet?',
    answer: 'Sí. Diseñamos nuestros sistemas POS para que sigan facturando aunque se caiga la conexión. Cuando el internet regresa, los datos se sincronizan automáticamente. En Honduras esto no es un lujo — es una necesidad.'
  },
  {
    question: '¿Sirve para mi tipo de negocio?',
    answer: 'Construimos el POS a la medida de tu operación: tiendas, minisúper, farmacias, ferreterías, boutiques, restaurantes, cafeterías, talleres y más. No es una plantilla genérica — es un sistema diseñado para cómo trabaja tu negocio.'
  },
  {
    question: '¿En cuánto tiempo estará listo mi punto de venta?',
    answer: 'Un sistema POS típico está funcionando en 4 a 8 semanas, dependiendo de la complejidad. Verás avances con demos funcionales cada dos semanas desde el inicio del proyecto.'
  },
  {
    question: '¿Dan soporte después de la entrega?',
    answer: 'Sí. Todos nuestros proyectos incluyen soporte post-lanzamiento, y estamos en Santa Rosa de Copán — si necesitás ayuda, respondemos rápido, en tu idioma y conociendo tu negocio. También damos soporte remoto a todo Honduras.'
  },
];
---

<Layout
  title="Sistema Punto de Venta (POS) en Honduras | Facturación e Inventario"
  description="Sistema punto de venta a la medida de tu negocio en Honduras: facturación, inventario, cierre de caja y reportes. Funciona sin internet. Para tiendas, farmacias, ferreterías y más. Consulta gratis."
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Sistema Punto de Venta en Honduras', url: '/sistema-pos-honduras' },
  ]}
  faq={faqs}
>

<div class="geo-page">
  <div class="container">

    <!-- Hero -->
    <div class="geo-hero">
      <p class="label-tag">Punto de Venta · Honduras</p>
      <h1 class="geo-title">
        Sistema Punto de Venta<br/>
        <span class="geo-em">hecho para tu negocio.</span>
      </h1>
      <p class="geo-lead">
        Facturación, inventario, cierre de caja y reportes en un solo sistema —
        construido a la medida de cómo trabaja tu negocio, no al revés.
        Desarrollado en Santa Rosa de Copán para todo Honduras.
      </p>
      <div class="geo-actions">
        <a href="/contacto" class="btn btn-primary">Cotización gratuita</a>
        <a href="https://wa.me/50433012826" class="btn btn-whatsapp" target="_blank" rel="noopener nofollow">WhatsApp →</a>
      </div>
    </div>

    <!-- Para quién -->
    <section class="geo-services">
      <h2 class="geo-section-title">Un POS para cada tipo de negocio en Honduras</h2>
      <div class="geo-grid">
        {negocios.map(n => (
          <div class="geo-card">
            <span class="geo-card-icon" set:html={n.icon} />
            <h3 class="geo-card-title">{n.title}</h3>
            <p class="geo-card-desc">{n.desc}</p>
          </div>
        ))}
      </div>
      <p class="geo-note">
        ¿Tenés un restaurante, cafetería o comedor? Mirá nuestro
        <a href="/sistema-para-restaurantes-honduras">sistema especializado para restaurantes</a>.
      </p>
    </section>

    <!-- Qué incluye -->
    <section class="geo-why">
      <h2 class="geo-section-title">Todo lo que tu punto de venta debe hacer</h2>
      <ul class="geo-features">
        {features.map(f => (
          <li class="geo-feature">
            <span class="gf-check">✓</span>
            {f}
          </li>
        ))}
      </ul>
    </section>

    <!-- Por qué a medida -->
    <section class="geo-why">
      <h2 class="geo-section-title">¿Por qué un POS a medida y no uno genérico?</h2>
      <div class="geo-why-grid">
        <div class="geo-why-item">
          <h3>Se adapta a tu operación</h3>
          <p>Los sistemas enlatados te obligan a cambiar cómo trabajás. El nuestro se construye alrededor de tus procesos, tus precios y tu forma de vender.</p>
        </div>
        <div class="geo-why-item">
          <h3>Sin mensualidades por usuario</h3>
          <p>El sistema es tuyo. No pagás licencias eternas por cada cajero ni te quedás atrapado con un proveedor extranjero que no responde.</p>
        </div>
        <div class="geo-why-item">
          <h3>Soporte local, en tu idioma</h3>
          <p>Estamos en Santa Rosa de Copán y atendemos todo Honduras. Cuando algo urge, hablás con quien construyó tu sistema — no con un call center.</p>
        </div>
        <div class="geo-why-item">
          <h3>Crece con tu negocio</h3>
          <p>¿Abrís otra sucursal? ¿Necesitás delivery o app móvil? Tu POS se amplía sin empezar de cero, porque fue diseñado para crecer.</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="geo-faq">
      <h2 class="geo-section-title">Preguntas frecuentes sobre sistemas POS</h2>
      <div class="geo-faq-list">
        {faqs.map(f => (
          <details class="geo-faq-item">
            <summary class="geo-faq-q">{f.question}</summary>
            <p class="geo-faq-a">{f.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="geo-cta">
      <h2 class="geo-cta-title">Tu punto de venta, funcionando en semanas.</h2>
      <p class="geo-cta-desc">Contanos cómo vende tu negocio hoy y te proponemos el sistema que necesita. Primera consulta gratis, sin compromiso.</p>
      <div class="geo-actions">
        <a href="/contacto" class="btn btn-primary">Iniciar proyecto</a>
        <a href="/desarrollo-software-honduras" class="btn btn-secondary">Ver más servicios en Honduras →</a>
      </div>
    </section>

  </div>
</div>

</Layout>

<style>
  .geo-page { padding: 5rem 0 7rem; }

  .geo-hero {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .geo-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.08;
    color: var(--text-1);
  }

  .geo-em {
    background: linear-gradient(115deg, #f0d080, #c8a040 40%, #e8b860 70%, #9a6a28);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .geo-lead {
    font-size: 0.95rem;
    color: var(--text-2);
    line-height: 1.75;
    font-weight: 300;
    max-width: 560px;
  }

  .geo-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .geo-section-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-1);
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .geo-services { margin-bottom: 5rem; }
  .geo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .geo-card {
    position: relative;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    background: var(--bg-1);
    overflow: hidden;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .geo-card::before {
    content: '';
    position: absolute;
    top: 0; left: 50%; transform: translateX(-50%);
    width: 60%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .geo-card:hover {
    border-color: var(--border-gold);
    transform: translateY(-2px);
  }
  .geo-card:hover::before { opacity: 1; }

  .geo-card-icon {
    width: 42px; height: 42px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg-3);
    display: flex; align-items: center; justify-content: center;
    color: var(--gold);
    margin-bottom: 0.9rem;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .geo-card:hover .geo-card-icon {
    background: rgba(200,169,110,0.1);
    border-color: var(--border-gold);
  }
  .geo-card-title { font-size: 1rem; font-weight: 600; color: var(--text-1); margin-bottom: 0.5rem; }
  .geo-card-desc { font-size: 0.82rem; color: var(--text-2); line-height: 1.7; font-weight: 300; }

  .geo-note {
    text-align: center;
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--text-2);
    font-weight: 300;
  }
  .geo-note a { color: var(--gold); text-decoration: underline; text-underline-offset: 3px; }

  .geo-features {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 0.5rem 2rem;
    max-width: 820px;
    margin: 0 auto;
  }
  .geo-feature {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    font-size: 0.875rem;
    color: var(--text-2);
    font-weight: 300;
    line-height: 1.6;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--border);
  }
  .gf-check {
    color: var(--gold);
    font-weight: 700;
    flex-shrink: 0;
  }

  .geo-why { margin-bottom: 5rem; }
  .geo-why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }
  .geo-why-item { padding: 1.5rem; border-left: 2px solid var(--gold); }
  .geo-why-item h3 { font-size: 0.9rem; font-weight: 600; color: var(--text-1); margin-bottom: 0.5rem; }
  .geo-why-item p { font-size: 0.82rem; color: var(--text-2); line-height: 1.7; font-weight: 300; }

  .geo-faq { margin-bottom: 5rem; max-width: 720px; margin-left: auto; margin-right: auto; }
  .geo-faq-list { display: flex; flex-direction: column; }

  .geo-faq-item {
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 0;
  }

  .geo-faq-q {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-1);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .geo-faq-q::-webkit-details-marker { display: none; }
  .geo-faq-q::after {
    content: '+';
    font-size: 1.2rem;
    color: var(--text-3);
    transition: transform 0.2s ease;
    flex-shrink: 0;
    margin-left: 1rem;
  }
  details[open] .geo-faq-q::after { content: '−'; }

  .geo-faq-a {
    font-size: 0.82rem;
    color: var(--text-2);
    line-height: 1.75;
    font-weight: 300;
    margin-top: 0.75rem;
    padding-right: 2rem;
  }

  .geo-cta {
    text-align: center;
    padding: 3rem;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--bg-1);
  }
  .geo-cta-title { font-size: 1.5rem; font-weight: 700; color: var(--text-1); margin-bottom: 0.75rem; letter-spacing: -0.02em; }
  .geo-cta-desc { font-size: 0.85rem; color: var(--text-2); line-height: 1.7; font-weight: 300; margin-bottom: 1.5rem; max-width: 450px; margin-left: auto; margin-right: auto; }
</style>
