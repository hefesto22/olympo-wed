---
import Layout from '../layouts/Layout.astro';

const cities = [
  'Santa Rosa de Copán', 'Copán Ruinas', 'La Entrada', 'Nueva Arcadia',
  'San Pedro de Copán', 'Florida', 'Dulce Nombre', 'Corquín',
];

const faqs = [
  {
    question: '¿Dónde están ubicados en Copán?',
    answer: 'Nuestra oficina principal está en Santa Rosa de Copán, la cabecera departamental de Copán. Atendemos clientes en todo el departamento incluyendo Copán Ruinas, La Entrada, Nueva Arcadia y más.'
  },
  {
    question: '¿Qué tipo de negocios en Copán necesitan software?',
    answer: 'Restaurantes, hoteles, comercios, clínicas, empresas de transporte, agroindustria, cooperativas y cualquier negocio que quiera optimizar sus operaciones con tecnología. Si manejas inventario, ventas, clientes o procesos repetitivos, un sistema a medida puede hacer la diferencia.'
  },
  {
    question: '¿Pueden hacer un sistema POS para mi negocio en Copán?',
    answer: 'Sí. Desarrollamos sistemas de punto de venta (POS) personalizados para la realidad de negocios en Copán. Incluyen facturación, inventario, reportes, y se adaptan a las regulaciones fiscales de Honduras.'
  },
  {
    question: '¿Ofrecen soporte técnico presencial en el departamento de Copán?',
    answer: 'Sí. Al estar basados en Santa Rosa de Copán, podemos brindar soporte presencial en todo el departamento. También ofrecemos soporte remoto por WhatsApp, email y videollamada.'
  },
];
---

<Layout
  title="Desarrollo de Software en Copán, Honduras | Olympo Code"
  description="Empresa de desarrollo de software en el departamento de Copán, Honduras. Software a medida, apps móviles, POS, ERP para negocios en Santa Rosa de Copán, Copán Ruinas, La Entrada y más."
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Desarrollo de Software en Copán', url: '/desarrollo-software-copan' },
  ]}
  faq={faqs}
>

<div class="geo-page">
  <div class="container">

    <!-- Hero -->
    <div class="geo-hero">
      <p class="label-tag">Departamento de Copán, Honduras</p>
      <h1 class="geo-title">
        Desarrollo de Software<br/>
        <span class="geo-em">en Copán, Honduras</span>
      </h1>
      <p class="geo-lead">
        Olympo Code es la empresa de desarrollo de software del departamento de Copán.
        Construimos sistemas a medida, apps móviles, automatizaciones y soluciones tecnológicas
        para negocios en Santa Rosa de Copán, Copán Ruinas, La Entrada y todo el occidente de Honduras.
      </p>
      <div class="geo-actions">
        <a href="/contacto" class="btn btn-primary">Solicitar consulta gratis</a>
        <a href="/servicios" class="btn btn-secondary">Ver servicios →</a>
      </div>
    </div>

    <!-- Cobertura -->
    <section class="geo-coverage">
      <h2 class="geo-section-title">Cobertura en el departamento de Copán</h2>
      <p class="geo-coverage-desc">
        Atendemos empresas y negocios en todo el departamento de Copán con reuniones presenciales y soporte remoto.
      </p>
      <div class="geo-cities">
        {cities.map(city => (
          <span class="geo-city-tag">{city}</span>
        ))}
      </div>
    </section>

    <!-- Servicios principales -->
    <section class="geo-highlights">
      <h2 class="geo-section-title">Lo que construimos para negocios en Copán</h2>
      <div class="geo-highlights-grid">
        <div class="geo-highlight">
          <h3>Sistemas POS y facturación</h3>
          <p>Punto de venta digital con control de inventario, facturación compatible con regulaciones hondureñas, y reportes de ventas en tiempo real para tu negocio.</p>
        </div>
        <div class="geo-highlight">
          <h3>ERP para empresas copanecas</h3>
          <p>Gestiona toda tu operación desde un solo sistema: compras, ventas, contabilidad, recursos humanos y reportes ejecutivos adaptados a tu industria.</p>
        </div>
        <div class="geo-highlight">
          <h3>Apps para turismo y comercio</h3>
          <p>Copán es referente turístico. Desarrollamos apps de reservas, menús digitales, guías turísticas y plataformas de e-commerce para negocios de la zona.</p>
        </div>
        <div class="geo-highlight">
          <h3>Automatización de procesos</h3>
          <p>Eliminamos el trabajo manual repetitivo. Reportes automáticos, sincronización entre sistemas, alertas y flujos que ahorran horas cada semana.</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="geo-faq">
      <h2 class="geo-section-title">Preguntas frecuentes</h2>
      <div class="geo-faq-list">
        {faqs.map(f => (
          <details class="geo-faq-item">
            <summary class="geo-faq-q">{f.question}</summary>
            <p class="geo-faq-a">{f.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="geo-cta">
      <h2 class="geo-cta-title">¿Tenés un negocio en Copán que necesita tecnología?</h2>
      <p class="geo-cta-desc">Hablemos. Primera consulta gratis, sin compromiso. Te respondemos en menos de 24 horas.</p>
      <div class="geo-actions">
        <a href="/contacto" class="btn btn-primary">Iniciar proyecto</a>
        <a href="https://wa.me/50433012826" class="btn btn-whatsapp" target="_blank" rel="noopener nofollow">WhatsApp →</a>
      </div>
    </section>

  </div>
</div>

</Layout>

<style>
  .geo-page { padding: 5rem 0 7rem; }

  .geo-hero {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .geo-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.08;
    color: var(--text-1);
  }

  .geo-em {
    background: linear-gradient(115deg, #f0d080, #c8a040 40%, #e8b860 70%, #9a6a28);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .geo-lead {
    font-size: 0.95rem;
    color: var(--text-2);
    line-height: 1.75;
    font-weight: 300;
    max-width: 560px;
  }

  .geo-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .geo-section-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-1);
    text-align: center;
    margin-bottom: 2.5rem;
  }

  /* Coverage */
  .geo-coverage { margin-bottom: 5rem; text-align: center; }
  .geo-coverage-desc {
    font-size: 0.9rem;
    color: var(--text-2);
    line-height: 1.7;
    font-weight: 300;
    max-width: 500px;
    margin: -1rem auto 2rem;
  }
  .geo-cities {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }
  .geo-city-tag {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-1);
    background: var(--bg-1);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 0.5rem 1.1rem;
    transition: all 0.15s ease;
  }
  .geo-city-tag:hover {
    border-color: var(--border-gold);
    background: rgba(200,169,110,0.06);
  }

  /* Highlights */
  .geo-highlights { margin-bottom: 5rem; }
  .geo-highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .geo-highlight {
    padding: 1.75rem;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--bg-1);
    transition: border-color 0.2s ease;
  }
  .geo-highlight:hover { border-color: var(--border-gold); }
  .geo-highlight h3 { font-size: 0.95rem; font-weight: 600; color: var(--text-1); margin-bottom: 0.5rem; }
  .geo-highlight p { font-size: 0.82rem; color: var(--text-2); line-height: 1.7; font-weight: 300; }

  /* FAQ */
  .geo-faq { margin-bottom: 5rem; max-width: 720px; margin-left: auto; margin-right: auto; }
  .geo-faq-list { display: flex; flex-direction: column; }
  .geo-faq-item { border-bottom: 1px solid var(--border); padding: 1.25rem 0; }
  .geo-faq-q {
    font-size: 0.9rem; font-weight: 500; color: var(--text-1);
    cursor: pointer; list-style: none;
    display: flex; justify-content: space-between; align-items: center;
  }
  .geo-faq-q::-webkit-details-marker { display: none; }
  .geo-faq-q::after { content: '+'; font-size: 1.2rem; color: var(--text-3); flex-shrink: 0; margin-left: 1rem; }
  details[open] .geo-faq-q::after { content: '−'; }
  .geo-faq-a { font-size: 0.82rem; color: var(--text-2); line-height: 1.75; font-weight: 300; margin-top: 0.75rem; padding-right: 2rem; }

  /* CTA */
  .geo-cta { text-align: center; padding: 3rem; border: 1px solid var(--border); border-radius: 16px; background: var(--bg-1); }
  .geo-cta-title { font-size: 1.5rem; font-weight: 700; color: var(--text-1); margin-bottom: 0.75rem; letter-spacing: -0.02em; }
  .geo-cta-desc { font-size: 0.85rem; color: var(--text-2); line-height: 1.7; font-weight: 300; margin-bottom: 1.5rem; max-width: 450px; margin-left: auto; margin-right: auto; }
</style>
