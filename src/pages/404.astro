---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada | Olympo Code" noindex={true}>
  <div class="not-found">
    <div class="nf-inner">
      <p class="label-tag">Error 404</p>
      <h1 class="nf-title">Esta página no existe.</h1>
      <p class="nf-desc">
        El enlace puede estar roto o la página fue movida.
        Aquí tienes algunos caminos útiles:
      </p>
      <nav class="nf-links" aria-label="Enlaces útiles">
        <a href="/">Inicio</a>
        <a href="/servicios">Servicios</a>
        <a href="/contacto">Contacto</a>
      </nav>
      <div class="nf-actions">
        <a href="/" class="btn btn-secondary">← Volver al inicio</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .not-found {
    min-height: calc(100vh - 56px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.25rem;
  }
  .nf-inner {
    text-align: center;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .nf-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--text-1);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }
  .nf-desc {
    font-size: 0.9rem;
    color: var(--text-2);
    line-height: 1.7;
    font-weight: 300;
    max-width: 380px;
  }
  .nf-links {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .nf-links a {
    font-size: 0.82rem;
    color: var(--gold);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }
  .nf-links a:hover { border-color: var(--gold); }
  .nf-actions { margin-top: 0.5rem; }
</style>
