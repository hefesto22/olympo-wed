---
// Landing de intención: "sistema para restaurantes Honduras", "sistema para cafetería", "POS restaurante"
import Layout from '../layouts/Layout.astro';

const tipos = [
  { icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 3v4.5M4.5 3v4.5a2 2 0 004 0V3M6.5 9.5V17"/><path d="M13.5 3v14M13.5 3c1.8 0 2.8 1.8 2.8 4.5 0 2.4-1 3.8-2.8 3.8"/></svg>', title: 'Restaurantes', desc: 'Control de mesas, comandas directas a cocina, cuentas separadas y propinas. Todo fluye desde que el cliente se sienta hasta que paga.' },
  { icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8h9.5v4.5a4 4 0 01-4 4H8a4 4 0 01-4-4V8z"/><path d="M13.5 9h1.5a2 2 0 010 4h-1.5"/><path d="M7 5.5c0-.8.7-1 .7-1.8M10 5.5c0-.8.7-1 .7-1.8"/></svg>', title: 'Cafeterías', desc: 'Ventas rápidas en barra, personalización de bebidas, combos y control de insumos como café, leche y azúcar por receta.' },
  { icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8.5a6 4.5 0 0112 0H4z"/><path d="M3.5 11.5h13"/><path d="M4 14.5h12v.5a2 2 0 01-2 2H6a2 2 0 01-2-2v-.5z"/></svg>', title: 'Comida rápida', desc: 'Pedidos para llevar, en mesa o delivery en la misma pantalla. Cocina ve cada orden al instante, sin papelitos que se pierden.' },
  { icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10h14a7 7 0 01-14 0z"/><path d="M8 6.5c0-1.4 4-1.4 4 0"/><path d="M6 17h8"/></svg>', title: 'Comedores y buffets', desc: 'Menú del día, precios por porción, control de raciones y reportes de qué platillos dejan más margen.' },
  { icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="5.5" cy="14" r="2.3"/><circle cx="14.5" cy="14" r="2.3"/><path d="M5.5 14l2.5-6h3l2 6"/><path d="M9.5 8H13l1.5 3"/><path d="M8 5.5h3"/></svg>', title: 'Delivery propio', desc: 'Pedidos por WhatsApp o app propia, asignación de repartidores y seguimiento de cada entrega sin pagar comisión a terceros.' },
  { icon: '<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 3.5h12L10 11v5.5"/><path d="M7 16.5h6M6 6h8"/></svg>', title: 'Bares y food trucks', desc: 'Cuentas abiertas por cliente, cortes de caja por turno y operación ágil aunque el local esté lleno.' },
];

const features = [
  'Comandas enviadas directo a cocina o barra',
  'Mapa de mesas con estado en tiempo real',
  'Facturación adaptada a los requisitos fiscales de Honduras (SAR)',
  'Control de insumos por receta — sabés cuánto cuesta cada platillo',
  'Cuentas separadas, propinas y descuentos sin enredos',
  'Menú digital con fotos, actualizable en segundos',
  'Reportes de platillos más vendidos y horas pico',
  'Funciona sin internet — el servicio no se detiene',
];

const faqs = [
  {
    question: '¿Cuánto cuesta un sistema para restaurante en Honduras?',
    answer: 'Un sistema para restaurante o cafetería con Olympo Code comienza desde $1,000 USD según las funcionalidades: comandas, mesas, inventario por receta, delivery y más. La primera consulta es gratuita — analizamos tu operación y te damos una cotización clara.'
  },
  {
    question: '¿El sistema envía las órdenes directo a la cocina?',
    answer: 'Sí. El mesero toma la orden en tablet o celular y la comanda aparece al instante en una pantalla o impresora en cocina. Sin gritos, sin papelitos perdidos y sin platos que nunca se pidieron.'
  },
  {
    question: '¿Puedo controlar el inventario de insumos?',
    answer: 'Sí. Cada platillo se define por receta: cuando vendés una baleada o un plato fuerte, el sistema descuenta automáticamente la harina, el queso o la carne del inventario. Sabés tu costo real y cuándo comprar.'
  },
  {
    question: '¿Funciona para cafeterías pequeñas o solo restaurantes grandes?',
    answer: 'Construimos el sistema a la medida de tu operación. Una cafetería de barra necesita algo distinto que un restaurante de 30 mesas — y por eso no vendemos plantillas, sino sistemas que se ajustan a tu tamaño y presupuesto.'
  },
  {
    question: '¿Atienden restaurantes fuera de Santa Rosa de Copán?',
    answer: 'Sí. Nuestra sede está en Santa Rosa de Copán, pero implementamos sistemas para restaurantes y cafeterías en todo Honduras — Tegucigalpa, San Pedro Sula, La Ceiba, Copán Ruinas y más. El soporte es remoto o presencial según la zona.'
  },
];
---

<Layout
  title="Sistema para Restaurantes y Cafeterías en Honduras | POS + Comandas"
  description="Sistema punto de venta para restaurantes, cafeterías y comedores en Honduras: comandas a cocina, control de mesas, inventario por receta y facturación. Hecho a tu medida. Consulta gratis."
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Sistema para Restaurantes en Honduras', url: '/sistema-para-restaurantes-honduras' },
  ]}
  faq={faqs}
>

<div class="geo-page">
  <div class="container">

    <!-- Hero -->
    <div class="geo-hero">
      <p class="label-tag">Restaurantes · Cafeterías · Honduras</p>
      <h1 class="geo-title">
        Sistema para restaurantes<br/>
        <span class="geo-em">que no detiene tu servicio.</span>
      </h1>
      <p class="geo-lead">
        Comandas a cocina, control de mesas, inventario por receta y facturación —
        en un solo sistema hecho a la medida de tu restaurante, cafetería o comedor.
        Desarrollado en Honduras, para negocios de comida hondureños.
      </p>
      <div class="geo-actions">
        <a href="/contacto" class="btn btn-primary">Cotización gratuita</a>
        <a href="https://wa.me/50433012826" class="btn btn-whatsapp" target="_blank" rel="noopener nofollow">WhatsApp →</a>
      </div>
    </div>

    <!-- Para quién -->
    <section class="geo-services">
      <h2 class="geo-section-title">Para cada tipo de negocio de comida</h2>
      <div class="geo-grid">
        {tipos.map(t => (
          <div class="geo-card">
            <span class="geo-card-icon" set:html={t.icon} />
            <h3 class="geo-card-title">{t.title}</h3>
            <p class="geo-card-desc">{t.desc}</p>
          </div>
        ))}
      </div>
      <p class="geo-note">
        ¿Tu negocio es una tienda, farmacia o ferretería? Mirá nuestro
        <a href="/sistema-pos-honduras">sistema punto de venta para comercios</a>.
      </p>
    </section>

    <!-- Qué incluye -->
    <section class="geo-why">
      <h2 class="geo-section-title">Lo que tu restaurante controla con el sistema</h2>
      <ul class="geo-features">
        {features.map(f => (
          <li class="geo-feature">
            <span class="gf-check">✓</span>
            {f}
          </li>
        ))}
      </ul>
    </section>

    <!-- Por qué -->
    <section class="geo-why">
      <h2 class="geo-section-title">El problema no es vender — es controlar</h2>
      <div class="geo-why-grid">
        <div class="geo-why-item">
          <h3>Sabé tu costo real por platillo</h3>
          <p>La mayoría de restaurantes no sabe cuánto le cuesta realmente cada plato. Con inventario por receta, el margen deja de ser un misterio.</p>
        </div>
        <div class="geo-why-item">
          <h3>Cocina y sala sincronizadas</h3>
          <p>Las comandas llegan al instante, en orden, con notas del cliente. Menos errores, mesas que rotan más rápido y clientes que vuelven.</p>
        </div>
        <div class="geo-why-item">
          <h3>Cierres de caja sin sorpresas</h3>
          <p>Cada turno cierra con su corte automático: ventas, propinas, métodos de pago. Los faltantes se detectan el mismo día, no a fin de mes.</p>
        </div>
        <div class="geo-why-item">
          <h3>Delivery sin comisiones</h3>
          <p>Recibí pedidos por WhatsApp o tu propia app sin pagar 20–30% a plataformas. El cliente es tuyo, los datos son tuyos, la ganancia es tuya.</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="geo-faq">
      <h2 class="geo-section-title">Preguntas frecuentes</h2>
      <div class="geo-faq-list">
        {faqs.map(f => (
          <details class="geo-faq-item">
            <summary class="geo-faq-q">{f.question}</summary>
            <p class="geo-faq-a">{f.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="geo-cta">
      <h2 class="geo-cta-title">Tu restaurante merece un sistema a su medida.</h2>
      <p class="geo-cta-desc">Contanos cómo opera tu negocio — mesas, barra, delivery — y te proponemos el sistema exacto que necesita. Consulta gratis.</p>
      <div class="geo-actions">
        <a href="/contacto" class="btn btn-primary">Iniciar proyecto</a>
        <a href="/desarrollo-software-honduras" class="btn btn-secondary">Ver más servicios en Honduras →</a>
      </div>
    </section>

  </div>
</div>

</Layout>

<style>
  .geo-page { padding: 5rem 0 7rem; }

  .geo-hero {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .geo-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.08;
    color: var(--text-1);
  }

  .geo-em {
    background: linear-gradient(115deg, #f0d080, #c8a040 40%, #e8b860 70%, #9a6a28);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .geo-lead {
    font-size: 0.95rem;
    color: var(--text-2);
    line-height: 1.75;
    font-weight: 300;
    max-width: 560px;
  }

  .geo-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .geo-section-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-1);
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .geo-services { margin-bottom: 5rem; }
  .geo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .geo-card {
    position: relative;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    background: var(--bg-1);
    overflow: hidden;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .geo-card::before {
    content: '';
    position: absolute;
    top: 0; left: 50%; transform: translateX(-50%);
    width: 60%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .geo-card:hover {
    border-color: var(--border-gold);
    transform: translateY(-2px);
  }
  .geo-card:hover::before { opacity: 1; }

  .geo-card-icon {
    width: 42px; height: 42px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg-3);
    display: flex; align-items: center; justify-content: center;
    color: var(--gold);
    margin-bottom: 0.9rem;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .geo-card:hover .geo-card-icon {
    background: rgba(200,169,110,0.1);
    border-color: var(--border-gold);
  }
  .geo-card-title { font-size: 1rem; font-weight: 600; color: var(--text-1); margin-bottom: 0.5rem; }
  .geo-card-desc { font-size: 0.82rem; color: var(--text-2); line-height: 1.7; font-weight: 300; }

  .geo-note {
    text-align: center;
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--text-2);
    font-weight: 300;
  }
  .geo-note a { color: var(--gold); text-decoration: underline; text-underline-offset: 3px; }

  .geo-features {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 0.5rem 2rem;
    max-width: 820px;
    margin: 0 auto;
  }
  .geo-feature {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    font-size: 0.875rem;
    color: var(--text-2);
    font-weight: 300;
    line-height: 1.6;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--border);
  }
  .gf-check {
    color: var(--gold);
    font-weight: 700;
    flex-shrink: 0;
  }

  .geo-why { margin-bottom: 5rem; }
  .geo-why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }
  .geo-why-item { padding: 1.5rem; border-left: 2px solid var(--gold); }
  .geo-why-item h3 { font-size: 0.9rem; font-weight: 600; color: var(--text-1); margin-bottom: 0.5rem; }
  .geo-why-item p { font-size: 0.82rem; color: var(--text-2); line-height: 1.7; font-weight: 300; }

  .geo-faq { margin-bottom: 5rem; max-width: 720px; margin-left: auto; margin-right: auto; }
  .geo-faq-list { display: flex; flex-direction: column; }

  .geo-faq-item {
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 0;
  }

  .geo-faq-q {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-1);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .geo-faq-q::-webkit-details-marker { display: none; }
  .geo-faq-q::after {
    content: '+';
    font-size: 1.2rem;
    color: var(--text-3);
    transition: transform 0.2s ease;
    flex-shrink: 0;
    margin-left: 1rem;
  }
  details[open] .geo-faq-q::after { content: '−'; }

  .geo-faq-a {
    font-size: 0.82rem;
    color: var(--text-2);
    line-height: 1.75;
    font-weight: 300;
    margin-top: 0.75rem;
    padding-right: 2rem;
  }

  .geo-cta {
    text-align: center;
    padding: 3rem;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--bg-1);
  }
  .geo-cta-title { font-size: 1.5rem; font-weight: 700; color: var(--text-1); margin-bottom: 0.75rem; letter-spacing: -0.02em; }
  .geo-cta-desc { font-size: 0.85rem; color: var(--text-2); line-height: 1.7; font-weight: 300; margin-bottom: 1.5rem; max-width: 450px; margin-left: auto; margin-right: auto; }
</style>
