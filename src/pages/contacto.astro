---
// src/pages/contacto.astro
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contacto | Desarrollo de Software en Copán, Honduras — Olympo Code"
  description="Contáctanos para tu proyecto de software en Honduras. Primera consulta gratis, sin compromiso. Desarrollo de apps, sistemas POS, ERP y más en Santa Rosa de Copán."
  breadcrumbs={[
    { name: 'Inicio', url: '/' },
    { name: 'Contacto', url: '/contacto' },
  ]}
>

  <div class="contact-page">

    <!-- Orb de fondo -->
    <div class="contact-orb" aria-hidden="true"></div>

    <div class="container">

      <!-- Header centrado -->
      <div class="contact-header">
        <p class="label-tag">Contacto</p>
        <h1 class="contact-title">
          Cuéntanos qué<br/>necesitas construir.
        </h1>
        <p class="contact-lead">
          Primera consulta sin costo y sin compromiso.
          Revisamos tu caso y te respondemos con un plan claro.
        </p>
      </div>

      <!-- Grid principal -->
      <div class="contact-grid">

        <!-- ── Columna izquierda ── -->
        <div class="contact-left">

          <div class="info-cards">
            <a href="https://wa.me/50433012826" class="info-card" target="_blank" rel="noopener nofollow">
              <div class="info-card-icon whatsapp-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              </div>
              <div class="info-card-body">
                <span class="info-card-label">WhatsApp</span>
                <span class="info-card-value">+504 3301 2826</span>
                <span class="info-card-hint">Respuesta rápida →</span>
              </div>
            </a>

            <a href="mailto:info@olympohn.com" class="info-card">
              <div class="info-card-icon email-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div class="info-card-body">
                <span class="info-card-label">Email</span>
                <span class="info-card-value">info@olympohn.com</span>
                <span class="info-card-hint">Menos de 24 horas →</span>
              </div>
            </a>
          </div>

          <!-- Divider -->
          <div class="info-divider"></div>

          <!-- Garantías -->
          <div class="guarantees">
            <p class="guarantees-title">Lo que puedes esperar</p>
            <div class="guarantee-list">
              <div class="guarantee-item">
                <div class="guarantee-dot"></div>
                <span>Primera consulta completamente gratis</span>
              </div>
              <div class="guarantee-item">
                <div class="guarantee-dot"></div>
                <span>Respuesta en menos de 24 horas hábiles</span>
              </div>
              <div class="guarantee-item">
                <div class="guarantee-dot"></div>
                <span>Propuesta técnica clara y sin letra pequeña</span>
              </div>
              <div class="guarantee-item">
                <div class="guarantee-dot"></div>
                <span>Sin compromiso de contratación</span>
              </div>
            </div>
          </div>

        </div>

        <!-- ── Columna derecha — formulario ── -->
        <div class="contact-right">
          <div class="form-card">

            <!-- Top glow line -->
            <div class="form-glow-line" aria-hidden="true"></div>

            <!-- Success state -->
            <div class="form-success" id="form-success">
              <div class="success-check">
                <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
                  <path d="M4 13l6 6L22 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3 class="success-title">¡Mensaje enviado!</h3>
              <p class="success-body">
                Recibimos tu mensaje y te respondemos en menos de 24 horas.
                Si necesitas respuesta más rápida, escríbenos por WhatsApp.
              </p>
              <a href="https://wa.me/50433012826" class="btn btn-whatsapp">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                Escribir por WhatsApp
              </a>
            </div>

            <!-- Form -->
            <form id="contact-form" action="https://formspree.io/f/xreyaqbo" method="POST">

              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="nombre">
                    Nombre completo <span class="req">*</span>
                  </label>
                  <input class="form-input" type="text" id="nombre" name="nombre" placeholder="Juan Pérez" required />
                </div>
                <div class="form-group">
                  <label class="form-label" for="email">
                    Email <span class="req">*</span>
                  </label>
                  <input class="form-input" type="email" id="email" name="email" placeholder="juan@empresa.com" required />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="telefono">Teléfono / WhatsApp</label>
                  <input class="form-input" type="tel" id="telefono" name="telefono" placeholder="+504 0000 0000" />
                </div>
                <div class="form-group">
                  <label class="form-label" for="servicio">
                    Tipo de servicio <span class="req">*</span>
                  </label>
                  <div class="select-wrap">
                    <select class="form-input form-select" id="servicio" name="servicio" required>
                      <option value="" disabled selected>Selecciona un servicio</option>
                      <option value="software-medida">Software a Medida (POS, ERP, CRM)</option>
                      <option value="app-movil">App Móvil</option>
                      <option value="api-integracion">API e Integraciones</option>
                      <option value="automatizacion">Automatizaciones N8N</option>
                      <option value="infraestructura">Infraestructura & Servidores</option>
                      <option value="consultoria">Consultoría IT</option>
                      <option value="otro">Otro / No estoy seguro</option>
                    </select>
                    <svg class="select-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                </div>
              </div>

              <div class="form-group">
                <label class="form-label" for="presupuesto">Presupuesto aproximado</label>
                <div class="select-wrap">
                  <select class="form-input form-select" id="presupuesto" name="presupuesto">
                    <option value="" disabled selected>¿Cuánto tienes en mente?</option>
                    <option value="menos-1k">Menos de $1,000</option>
                    <option value="1k-5k">$1,000 – $5,000</option>
                    <option value="5k-15k">$5,000 – $15,000</option>
                    <option value="15k-50k">$15,000 – $50,000</option>
                    <option value="mas-50k">Más de $50,000</option>
                    <option value="no-se">No lo tengo definido aún</option>
                  </select>
                  <svg class="select-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
              </div>

              <div class="form-group">
                <label class="form-label" for="descripcion">
                  Descripción del proyecto <span class="req">*</span>
                </label>
                <textarea
                  class="form-input form-textarea"
                  id="descripcion"
                  name="descripcion"
                  placeholder="Cuéntanos qué necesitas construir, qué problema resuelve y cualquier detalle relevante..."
                  rows="4"
                  required
                ></textarea>
              </div>

              <p class="form-error" id="form-error">
                Algo salió mal. Intenta de nuevo o escríbenos por WhatsApp.
              </p>

              <button type="submit" class="btn-submit" id="submit-btn">
                <span id="btn-text">Enviar mensaje</span>
                <svg id="btn-arrow" width="15" height="15" viewBox="0 0 15 15" fill="none">
                  <path d="M3 7.5h9M8.5 3.5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <svg id="btn-spinner" class="spinner" width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2" stroke-dasharray="25 13" stroke-linecap="round"/>
                </svg>
              </button>

              <p class="form-note">
                Al enviar aceptas que te contactemos para responderte.
              </p>

            </form>
          </div>
        </div>

      </div>
    </div>
  </div>

</Layout>

<style>
  .contact-page {
    position: relative;
    padding: 5rem 0 7rem;
    min-height: calc(100vh - 56px);
    overflow: hidden;
  }

  /* Orb de fondo */
  .contact-orb {
    position: absolute;
    top: -200px; left: 50%; transform: translateX(-50%);
    width: 700px; height: 500px;
    background: radial-gradient(ellipse, rgba(200,169,110,0.06) 0%, transparent 70%);
    filter: blur(60px);
    pointer-events: none;
  }

  /* Header centrado */
  .contact-header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.65rem;
  }

  .contact-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text-1);
    letter-spacing: -0.04em;
    line-height: 1.05;
  }

  .contact-lead {
    font-size: 0.9rem;
    color: var(--text-2);
    line-height: 1.75;
    font-weight: 300;
    max-width: 420px;
  }

  /* Grid */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 3.5rem;
    align-items: start;
    max-width: 960px;
    margin: 0 auto;
  }
  @media (max-width: 860px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  /* ── Info cards ── */
  .info-cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  .info-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg-1);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
  }
  .info-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .info-card:hover {
    border-color: var(--border-gold);
    background: rgba(200,169,110,0.04);
    transform: translateY(-1px);
  }
  .info-card:hover::before { opacity: 1; }

  .info-card-icon {
    width: 42px; height: 42px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    border: 1px solid var(--border);
  }
  .whatsapp-icon { background: rgba(37,211,102,0.1); color: #25d366; border-color: rgba(37,211,102,0.2); }
  .email-icon    { background: rgba(200,169,110,0.1); color: var(--gold); border-color: var(--border-gold); }

  .info-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    flex: 1;
  }
  .info-card-label {
    font-size: 0.58rem;
    font-family: var(--font-mono);
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .info-card-value {
    font-size: 0.85rem;
    color: var(--text-1);
    font-weight: 500;
  }
  .info-card-hint {
    font-size: 0.65rem;
    color: var(--text-3);
    font-family: var(--font-mono);
  }

  .info-divider {
    height: 1px;
    background: linear-gradient(90deg, var(--border), transparent);
    margin-bottom: 1.75rem;
  }

  /* Garantías */
  .guarantees-title {
    font-size: 0.68rem;
    font-family: var(--font-mono);
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.85rem;
  }

  .guarantee-list {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .guarantee-item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.8rem;
    color: var(--text-2);
    font-weight: 300;
  }

  .guarantee-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--gold);
    opacity: 0.6;
    flex-shrink: 0;
  }

  /* ── Form card ── */
  .form-card {
    position: relative;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--bg-1);
    padding: 2rem;
    overflow: hidden;
  }
  @media (min-width: 640px) { .form-card { padding: 2.25rem; } }

  .form-glow-line {
    position: absolute;
    top: 0; left: 50%; transform: translateX(-50%);
    width: 55%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }

  /* Success */
  .form-success {
    display: none;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    padding: 2.5rem 1rem;
  }

  .success-check {
    width: 60px; height: 60px;
    border-radius: 50%;
    background: rgba(34,197,94,0.1);
    border: 1px solid rgba(34,197,94,0.25);
    display: flex; align-items: center; justify-content: center;
    color: #22c55e;
  }

  .success-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-1);
    letter-spacing: -0.02em;
  }

  .success-body {
    font-size: 0.82rem;
    color: var(--text-2);
    line-height: 1.7;
    font-weight: 300;
    max-width: 300px;
  }

  /* Form rows */
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
    margin-bottom: 0.85rem;
  }
  @media (max-width: 480px) { .form-row { grid-template-columns: 1fr; } }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 0.85rem;
  }
  .form-row .form-group { margin-bottom: 0; }

  .form-label {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--text-2);
    letter-spacing: 0.01em;
  }
  .req { color: var(--gold); }

  .form-input {
    width: 100%;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.65rem 0.9rem;
    font-size: 0.82rem;
    font-family: var(--font-sans);
    color: var(--text-1);
    outline: none;
    transition: border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
    -webkit-appearance: none;
  }
  .form-input::placeholder { color: var(--text-3); }
  .form-input:focus {
    border-color: var(--border-gold);
    background: var(--bg-3);
    box-shadow: 0 0 0 3px rgba(200,169,110,0.08);
  }

  .select-wrap { position: relative; }
  .form-select { cursor: pointer; padding-right: 2.5rem; }
  .form-select option { background: var(--bg-3); color: var(--text-1); }
  .select-chevron {
    position: absolute;
    right: 0.85rem; top: 50%; transform: translateY(-50%);
    color: var(--text-3); pointer-events: none;
  }

  .form-textarea {
    resize: vertical;
    min-height: 110px;
    line-height: 1.6;
  }

  .form-error {
    display: none;
    font-size: 0.75rem;
    color: #f87171;
    background: rgba(248,113,113,0.08);
    border: 1px solid rgba(248,113,113,0.2);
    border-radius: var(--radius);
    padding: 0.6rem 0.85rem;
    margin-bottom: 0.85rem;
  }

  /* Submit button */
  .btn-submit {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.9rem;
    background: var(--text-1);
    color: #080808;
    font-size: 0.875rem;
    font-weight: 600;
    font-family: var(--font-sans);
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    transition: background 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
    margin-top: 0.25rem;
  }
  .btn-submit:hover {
    background: #fff;
    box-shadow: 0 0 24px rgba(245,245,240,0.15);
    transform: translateY(-1px);
  }
  .btn-submit:active { transform: translateY(0); }
  .btn-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .spinner { animation: spin 0.8s linear infinite; display: none; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .form-note {
    font-size: 0.62rem;
    color: var(--text-3);
    text-align: center;
    margin-top: 0.65rem;
    font-family: var(--font-mono);
    line-height: 1.5;
  }
</style>

<script>
const form       = document.getElementById('contact-form') as HTMLFormElement;
const successEl  = document.getElementById('form-success') as HTMLElement;
const errorEl    = document.getElementById('form-error') as HTMLElement;
const submitBtn  = document.getElementById('submit-btn') as HTMLButtonElement;
const btnText    = document.getElementById('btn-text') as HTMLElement;
const btnArrow   = document.getElementById('btn-arrow') as HTMLElement;
const btnSpinner = document.getElementById('btn-spinner') as HTMLElement;

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  errorEl.style.display = 'none';

  // Loading
  submitBtn.disabled = true;
  btnText.textContent = 'Enviando...';
  btnArrow.style.display = 'none';
  btnSpinner.style.display = 'block';

  try {
    const res = await fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' },
    });

    if (res.ok) {
      form.style.display = 'none';
      successEl.style.display = 'flex';
    } else {
      throw new Error();
    }
  } catch {
    errorEl.style.display = 'block';
    submitBtn.disabled = false;
    btnText.textContent = 'Enviar mensaje';
    btnArrow.style.display = 'block';
    btnSpinner.style.display = 'none';
  }
});
</script>