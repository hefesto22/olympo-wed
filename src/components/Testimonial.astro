---
// src/components/Testimonial.astro

const testimonial = {
  quote:  'Olympo entregó nuestro sistema POS en tiempo récord. Hoy procesamos cientos de ventas diarias sin un solo fallo. El código es nuestro, la documentación es clara, y el equipo respondió siempre que los necesitamos.',
  name:   'Juan Solís',
  role:   'CEO — Distribuidora Sol, Honduras',
  initials: 'JS',
};
---

<section class="section testimonial-section">
  <div class="container">
    <div class="testimonial-card reveal">
      <div class="testimonial-glow" aria-hidden="true"></div>

      <div class="testimonial-quote">"</div>

      <blockquote class="testimonial-text">
        {testimonial.quote}
      </blockquote>

      <div class="testimonial-author">
        <div class="author-avatar">{testimonial.initials}</div>
        <div>
          <div class="author-name">{testimonial.name}</div>
          <div class="author-role">{testimonial.role}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.testimonial-section {
  padding: 3rem 0;
}

.testimonial-card {
  position: relative;
  padding: 3rem 2rem;
  border: 1px solid var(--border);
  border-radius: 12px;
  background: var(--bg-1);
  max-width: 740px;
  margin: 0 auto;
  text-align: center;
  overflow: hidden;
}
@media (min-width: 640px) {
  .testimonial-card { padding: 3.5rem 4rem; }
}

.testimonial-glow {
  position: absolute;
  top: 0; left: 50%; transform: translateX(-50%);
  width: 400px; height: 200px;
  background: radial-gradient(ellipse at top, rgba(200,169,110,0.06), transparent 70%);
  pointer-events: none;
}

/* Línea dorada superior */
.testimonial-card::before {
  content: '';
  position: absolute;
  top: 0; left: 50%; transform: translateX(-50%);
  width: 40%; height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}

.testimonial-quote {
  font-size: 5rem;
  line-height: 1;
  color: var(--gold);
  opacity: 0.2;
  margin-bottom: -1.5rem;
  font-style: italic;
  font-weight: 700;
}

.testimonial-text {
  font-size: clamp(0.95rem, 1.8vw, 1.05rem);
  color: var(--text-2);
  line-height: 1.8;
  font-weight: 300;
  font-style: italic;
  margin-bottom: 2rem;
}

.testimonial-author {
  display: inline-flex;
  align-items: center;
  gap: 0.85rem;
}

.author-avatar {
  width: 38px; height: 38px;
  border-radius: 50%;
  background: rgba(200,169,110,0.1);
  border: 1px solid var(--border-gold);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.7rem; font-weight: 600;
  color: var(--gold);
  font-family: var(--font-mono);
  flex-shrink: 0;
}

.author-name {
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--text-1);
}

.author-role {
  font-size: 0.68rem;
  color: var(--text-3);
  font-family: var(--font-mono);
}
</style>