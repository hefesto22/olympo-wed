---
// src/components/CTA.astro
---

<section class="section cta-section">
    <div class="container">
      <div class="cta-block reveal">
  
        <div class="cta-orb" aria-hidden="true"></div>
  
        <!-- Contenido -->
        <div class="cta-inner">
          <p class="label-tag" style="color:var(--gold); justify-content:center;">¿Tienes un proyecto?</p>
          <h2 class="cta-h2">
            Hablemos sobre lo<br/>que necesitas construir.
          </h2>
          <p class="cta-body">Primera consulta sin costo. Sin compromisos. En 24 h te respondemos.</p>
  
          <div class="cta-actions">
            <a href="/contacto" class="btn btn-primary btn-lg">
              Agendar consulta
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="https://wa.me/50433012826" class="btn btn-whatsapp btn-lg">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
              WhatsApp
            </a>
          </div>
        </div>
  
      </div>
    </div>
  </section>
  
  <style>
  .cta-section {
    padding-bottom: 6rem;
  }
  
  .cta-block {
    position: relative;
    border-radius: 16px;
    border: 1px solid var(--border);
    overflow: hidden;
    background: var(--bg-1);
  }
  
  /* Glow radial de fondo */
  .cta-block::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% -10%, rgba(200,169,110,0.09), transparent 60%),
      radial-gradient(ellipse 40% 40% at 80% 80%, rgba(200,169,110,0.04), transparent 60%);
    pointer-events: none;
  }
  
  /* Línea dorada superior */
  .cta-block::after {
    content: '';
    position: absolute;
    top: 0; left: 50%; transform: translateX(-50%);
    width: 50%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }
  
  .cta-orb {
    position: absolute;
    top: -80px; left: 50%; transform: translateX(-50%);
    width: 500px; height: 300px;
    background: radial-gradient(ellipse, rgba(200,169,110,0.07), transparent 70%);
    pointer-events: none;
    filter: blur(40px);
  }
  
  .cta-inner {
    position: relative; z-index: 1;
    text-align: center;
    padding: 4rem 1.5rem;
  }
  @media (min-width: 640px) { .cta-inner { padding: 5rem 3rem; } }
  
  .cta-h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    color: var(--text-1);
    line-height: 1.1;
    margin: 0.65rem 0 0.75rem;
  }
  
  .cta-body {
    font-size: 0.875rem;
    color: var(--text-2);
    margin-bottom: 2rem;
    font-weight: 300;
    line-height: 1.7;
  }
  
  .cta-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  </style>