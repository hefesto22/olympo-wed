---
const year = new Date().getFullYear();

const cols = [
  {
    heading: 'Servicios',
    links: [
      { label: 'Software a Medida',    href: '/servicios#software-medida' },
      { label: 'Apps Móviles',         href: '/servicios#apps-moviles' },
      { label: 'APIs & Integraciones', href: '/servicios#apis-integraciones' },
      { label: 'Automatizaciones N8N', href: '/servicios#automatizaciones' },
      { label: 'Infraestructura',      href: '/servicios#infraestructura' },
      { label: 'Consultoría IT',       href: '/servicios#consultoria' },
    ],
  },
  {
    heading: 'Soluciones',
    links: [
      { label: 'Sistema Punto de Venta (POS)',     href: '/sistema-pos-honduras' },
      { label: 'Sistema para Restaurantes',        href: '/sistema-para-restaurantes-honduras' },
      { label: 'Software en Santa Rosa de Copán',  href: '/desarrollo-software-santa-rosa-de-copan' },
      { label: 'Software en Copán',                href: '/desarrollo-software-copan' },
      { label: 'Software en Honduras',             href: '/desarrollo-software-honduras' },
      { label: 'Contacto',                         href: '/contacto' },
    ],
  },
  {
    heading: 'Contacto',
    links: [
      { label: 'info@olympohn.com', href: 'mailto:info@olympohn.com' },
      { label: '+504 3301 2826',    href: 'tel:+50433012826' },
      { label: 'Santa Rosa de Copán, Honduras', href: '/desarrollo-software-santa-rosa-de-copan' },
    ],
  },
];
---

<footer>
  <div class="container">

    <div class="footer-top">

      <div class="footer-brand">
        <a href="/" class="brand-logo">
          <img src="/og-image.webp" alt="Olympo Code — Empresa de Desarrollo de Software en Santa Rosa de Copán, Honduras" class="footer-logo-img" width="260" height="136" loading="lazy" />
        </a>
        <div class="brand-social">
          <a href="https://linkedin.com" class="social-link" aria-label="LinkedIn" target="_blank" rel="noopener nofollow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://github.com" class="social-link" aria-label="GitHub" target="_blank" rel="noopener nofollow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
          <a href="https://wa.me/50433012826" class="social-link" aria-label="WhatsApp" target="_blank" rel="noopener nofollow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          </a>
        </div>
      </div>

      {cols.map(col => (
        <div class="footer-col">
          <p class="col-heading">{col.heading}</p>
          <ul>
            {col.links.map(l => (
              <li><a href={l.href} class="col-link">{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}

    </div>

    <div class="footer-bottom">
      <p class="copy">© {year} Olympo Code. Todos los derechos reservados.</p>
      <a href="/contacto" class="footer-cta">¿Tienes un proyecto? Hablemos →</a>
      <p class="made">Hecho en Honduras 🇭🇳</p>
    </div>

  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    background: var(--bg);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    padding: 3rem 0 2.5rem;
  }
  @media (min-width: 640px) {
    .footer-top { grid-template-columns: 1fr 1fr 1fr; }
  }
  @media (min-width: 900px) {
    .footer-top {
      grid-template-columns: 1.8fr 1fr 1fr 1fr;
      gap: 3rem;
      padding: 4rem 0 3rem;
    }
  }

  .footer-brand { grid-column: 1 / -1; }
  @media (min-width: 900px) { .footer-brand { grid-column: auto; } }

  .brand-logo { display: block; margin-bottom: 1.25rem; }
  .footer-logo-img {
    width: 100%;
    max-width: 260px;
    height: auto;
    object-fit: cover;
    border-radius: 6px;
    opacity: 0.9;
    transition: opacity var(--transition);
  }
  .brand-logo:hover .footer-logo-img { opacity: 1; }

  .brand-tagline {
    font-size: 0.82rem;
    color: var(--text-2);
    line-height: 1.65;
    margin-bottom: 0.35rem;
    font-weight: 300;
  }

  .brand-location {
    font-size: 0.72rem;
    color: var(--text-3);
    font-family: var(--font-mono);
    margin-bottom: 1.25rem;
    letter-spacing: 0.02em;
  }

  .brand-social { display: flex; gap: 0.5rem; }
  .social-link {
    width: 32px; height: 32px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    display: flex; align-items: center; justify-content: center;
    color: var(--text-3);
    transition: all var(--transition);
  }
  .social-link:hover {
    border-color: var(--border-hover);
    color: var(--text-1);
    background: var(--bg-2);
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .col-heading {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 0.9rem;
    font-family: var(--font-mono);
  }
  .col-link {
    font-size: 0.8rem;
    color: var(--text-2);
    font-weight: 300;
    transition: color var(--transition);
    word-break: break-all;
  }
  .col-link:hover { color: var(--text-1); }

  .footer-bottom {
    border-top: 1px solid var(--border);
    padding: 1.25rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }
  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
  .copy, .made { font-size: 0.72rem; color: var(--text-3); }
  .footer-cta {
    font-size: 0.72rem;
    color: var(--gold);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    transition: opacity var(--transition);
  }
  .footer-cta:hover { opacity: 0.7; }
</style>