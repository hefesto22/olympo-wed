---
// src/components/Process.astro

const steps = [
  {
    step: '01',
    title: 'Entendemos tu negocio',
    desc:  'Antes de escribir una sola línea de código, nos sentamos contigo. Mapeamos tus procesos, identificamos el problema real y definimos juntos qué necesita construirse — y qué no.',
    detail: 'Sin costo · Sin compromiso',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.4"/><path d="M10 6.5V10l2.5 1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    step: '02',
    title: 'Propuesta sin letra pequeña',
    desc:  'Recibes una propuesta técnica clara: qué vamos a construir, con qué tecnología, cómo se va a estructurar y cuánto va a costar. Sin ambigüedades, sin sorpresas después.',
    detail: 'Alcance · Stack · Costo real',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="14" height="14" rx="2.5" stroke="currentColor" stroke-width="1.4"/><path d="M6.5 7.5h7M6.5 10h5M6.5 12.5h6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
  },
  {
    step: '03',
    title: 'Construimos en ciclos cortos',
    desc:  'Trabajamos en sprints con entregas reales que puedes ver, tocar y criticar. Si algo no va como esperabas, lo corregimos antes de seguir — no al final cuando ya es tarde y costoso.',
    detail: 'Demos reales · Control total',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><polyline points="4,10 8,6 12,13 15,9 18,11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    step: '04',
    title: 'Lanzamos y acompañamos',
    desc:  'El deploy es solo el comienzo. Documentamos todo, capacitamos a tu equipo si es necesario y nos quedamos cerca post-lanzamiento. El sistema es tuyo — y nos aseguramos de que funcione.',
    detail: 'Deploy · Docs · Soporte',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10.5l4.5 4.5L16 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
];
---

<section class="section process-section">
  <div class="container">

    <div class="section-header center-header">
      <p class="label-tag">Proceso</p>
      <h2 class="section-h2">Así trabajamos.</h2>
      <p class="process-sub">Sin metodologías complicadas. Sin sorpresas. Solo resultados.</p>
    </div>

    <!-- Desktop timeline -->
    <div class="timeline-desktop">
      <!-- Línea conectora -->
      <div class="tl-track" aria-hidden="true">
        <div class="tl-fill"></div>
      </div>

      <div class="tl-steps">
        {steps.map((s, i) => (
          <div class="tl-step reveal" style={`transition-delay:${i * 90}ms`}>
            <!-- Nodo -->
            <div class="tl-node">
              <span class="tl-node-icon" set:html={s.icon} />
            </div>
            <!-- Texto -->
            <div class="tl-body">
              <span class="tl-num">{s.step}</span>
              <h4 class="tl-title">{s.title}</h4>
              <p class="tl-desc">{s.desc}</p>
              <span class="tl-badge">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="currentColor" stroke-width="1"/><path d="M5 3v2.5l1.5 1" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>
                {s.detail}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile timeline -->
    <div class="timeline-mobile">
      {steps.map((s, i) => (
        <div class="tm-step reveal" style={`transition-delay:${i * 90}ms`}>
          <div class="tm-left">
            <div class="tm-node">
              <span set:html={s.icon} />
            </div>
            {i < steps.length - 1 && <div class="tm-vline"></div>}
          </div>
          <div class="tm-body">
            <span class="tl-num">{s.step}</span>
            <h4 class="tl-title">{s.title}</h4>
            <p class="tl-desc">{s.desc}</p>
            <span class="tl-badge">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="currentColor" stroke-width="1"/><path d="M5 3v2.5l1.5 1" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>
              {s.detail}
            </span>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="process-cta reveal">
      <p class="process-cta-text">La primera consulta no cuesta nada.</p>
      <a href="/contacto" class="btn btn-primary">
        Agendar consulta gratuita
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
          <path d="M2.5 6.5h8M7 3l3.5 3.5L7 10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
.process-section {
  background: var(--bg);
}
.process-sub {
  font-size: 0.875rem; color: var(--text-2);
  margin-top: 0.5rem; font-weight: 300;
}

/* ────────────────────────────
   DESKTOP TIMELINE (≥768px)
──────────────────────────── */
.timeline-desktop { display: block; }
.timeline-mobile  { display: none;  }

@media (max-width: 767px) {
  .timeline-desktop { display: none;  }
  .timeline-mobile  { display: block; }
}

/* Track line */
.tl-track {
  position: relative;
  height: 1px;
  background: var(--border);
  margin: 0 calc(12.5%);
  margin-bottom: 0;
  top: 29px; /* Alineado con el centro del nodo */
  z-index: 0;
}
.tl-fill {
  position: absolute; top: 0; left: 0;
  height: 100%; width: 0;
  background: linear-gradient(90deg, var(--gold), var(--gold-dim));
  transition: width 1.4s ease 0.2s;
}
.tl-fill.animated { width: 100%; }

/* Steps row */
.tl-steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  position: relative;
  z-index: 1;
}

.tl-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 0 1.25rem;
  cursor: default;
}

/* Node */
.tl-node {
  width: 56px; height: 56px;
  border-radius: 50%;
  border: 1px solid var(--border);
  background: var(--bg-2);
  display: flex; align-items: center; justify-content: center;
  color: var(--text-3);
  margin-bottom: 1.5rem;
  transition: all 0.3s ease;
  position: relative;
}
.tl-node::after {
  content: '';
  position: absolute; inset: -5px;
  border-radius: 50%;
  border: 1px solid transparent;
  transition: border-color 0.3s ease;
}
.tl-step:hover .tl-node {
  background: rgba(200,169,110,0.1);
  border-color: var(--border-gold);
  color: var(--gold);
}
.tl-step:hover .tl-node::after {
  border-color: rgba(200,169,110,0.18);
}
.tl-node-icon { display: flex; }

/* Body */
.tl-num {
  display: block;
  font-family: var(--font-mono);
  font-size: 0.6rem; color: var(--gold);
  letter-spacing: 0.1em; margin-bottom: 0.35rem;
}
.tl-title {
  font-size: 0.9rem; font-weight: 600;
  color: var(--text-1); letter-spacing: -0.01em;
  margin-bottom: 0.45rem;
}
.tl-desc {
  font-size: 0.76rem; color: var(--text-2);
  line-height: 1.65; font-weight: 300;
  margin-bottom: 0.75rem;
}
.tl-badge {
  display: inline-flex; align-items: center; gap: 0.35rem;
  font-size: 0.6rem; font-family: var(--font-mono); color: var(--text-3);
  background: var(--bg-3); border: 1px solid var(--border);
  border-radius: 100px; padding: 0.2rem 0.6rem;
}

/* ────────────────────────────
   MOBILE TIMELINE (<768px)
──────────────────────────── */
.tm-step {
  display: flex;
  gap: 1.25rem;
  padding-bottom: 1.75rem;
}
.tm-step:last-child { padding-bottom: 0; }

.tm-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.tm-node {
  width: 44px; height: 44px;
  border-radius: 50%;
  border: 1px solid var(--border);
  background: var(--bg-2);
  display: flex; align-items: center; justify-content: center;
  color: var(--text-3);
  flex-shrink: 0;
}

.tm-vline {
  width: 1px;
  flex: 1;
  min-height: 24px;
  background: linear-gradient(to bottom, var(--border-gold), var(--border));
  margin-top: 6px;
}

.tm-body {
  padding-top: 0.25rem;
  padding-bottom: 0.5rem;
}

/* ── CTA ── */
.process-cta {
  display: flex; align-items: center;
  justify-content: center; gap: 1.25rem;
  margin-top: 4rem; flex-wrap: wrap;
}
.process-cta-text {
  font-size: 0.875rem; color: var(--text-2);
}
</style>

<script>
const fill = document.querySelector('.tl-fill') as HTMLElement | null;
if (fill) {
  new IntersectionObserver(([e]) => {
    if (e.isIntersecting) fill.classList.add('animated');
  }, { threshold: 0.4 }).observe(fill.closest('.tl-track')!);
}
</script>