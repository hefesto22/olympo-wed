  let isDragging  = false;
  let isJumping   = false;
  
  // ── Clonar cards para loop infinito ──
  // Clonamos todas al inicio y al final
  const makeClone = (c: HTMLElement) => {
    const cl = c.cloneNode(true) as HTMLElement;
    cl.setAttribute('aria-hidden', 'true');
    // Un elemento aria-hidden no debe contener elementos enfocables
    cl.querySelectorAll<HTMLElement>('button, a, [tabindex]').forEach(el => { el.tabIndex = -1; });
    return cl;
  };
  const clonesBefore = origCards.map(makeClone);
  const clonesAfter  = origCards.map(makeClone);
  
  clonesBefore.reverse().forEach(cl => carousel.prepend(cl));
  clonesAfter.forEach(cl => carousel.append(cl));
  
  // Todas las cards (clones + reales + clones)
  const allCards = () => Array.from(carousel.querySelectorAll<HTMLElement>('.svc-card'));
  
  // ── Dots solo para las originales ──
  origCards.forEach((_, i) => {
    const dot = document.createElement('button');
    dot.className = 'svc-dot' + (i === 0 ? ' active' : '');
    dot.setAttribute('aria-label', `Ir al servicio ${i + 1}`);
    dot.addEventListener('click', () => goTo(i));
    dotsEl.appendChild(dot);
  });
  
  function getCardWidth(): number {
    const c = allCards()[0];
    return c ? c.offsetWidth + parseInt(getComputedStyle(carousel).gap || '20') : 0;
  }
  
  // Ir a index real (0-based sobre originales)
  function goTo(index: number, instant = false) {
    current = ((index % total) + total) % total;
    const realIndex = current + total; // offset por los clones del inicio
    const cards = allCards();
    const target = cards[realIndex];
    if (!target) return;
    const offset = target.offsetLeft - carousel.offsetLeft;
    if (instant) {
      carousel.style.scrollBehavior = 'auto';
      carousel.scrollLeft = offset;
      requestAnimationFrame(() => { carousel.style.scrollBehavior = 'smooth'; });
    } else {
      carousel.style.scrollBehavior = 'smooth';
      carousel.scrollTo({ left: offset, behavior: 'smooth' });
    }
    updateUI();
  }
  
  function updateUI() {
    dotsEl.querySelectorAll('.svc-dot').forEach((d, i) =>
      d.classList.toggle('active', i === current)
    );
    // Infinito: nunca deshabilitar botones
    prevBtn.disabled = false;
    nextBtn.disabled = false;
  }
  
  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));
  
  // ── Inicializar en la primera card real ──
  requestAnimationFrame(() => goTo(0, true));
  
  // ── Loop infinito: jump silencioso al detectar clones ──
  let scrollTimer: ReturnType<typeof setTimeout>;
  carousel.addEventListener('scroll', () => {
    if (isJumping) return;
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(() => {
      const cardW = getCardWidth();
      if (!cardW) return;
      const rawIndex = Math.round(carousel.scrollLeft / cardW);
      const cards    = allCards();
  
      // Si estamos en los clones del final → saltar al inicio real
      if (rawIndex >= total * 2) {
        isJumping = true;
        current = rawIndex - total * 2;
        goTo(current, true);
        setTimeout(() => { isJumping = false; }, 50);
      }
      // Si estamos en los clones del inicio → saltar al final real
      else if (rawIndex < total) {
        isJumping = true;
        current = rawIndex + total;
        goTo(current % total, true);
        setTimeout(() => { isJumping = false; }, 50);
      }
      // Normal
      else {
        current = (rawIndex - total + total) % total;
        updateUI();
      }
    }, 60);
  }, { passive: true });
  
  // ── Drag con mouse ──
  let startX = 0, startScroll = 0;
  
  carousel.addEventListener('mousedown', e => {
    isDragging = true;
    startX = e.pageX;
    startScroll = carousel.scrollLeft;
    carousel.style.scrollBehavior = 'auto';
    carousel.style.cursor = 'grabbing';
  });
  
  window.addEventListener('mouseup', () => {
    if (!isDragging) return;
    isDragging = false;
    carousel.style.cursor = 'grab';
    // Snap a la card más cercana
    const cardW = getCardWidth();
    const rawIndex = Math.round(carousel.scrollLeft / cardW);
    const cards = allCards();
    if (rawIndex >= 0 && rawIndex < cards.length) {
      const offset = cards[rawIndex].offsetLeft - carousel.offsetLeft;
      carousel.style.scrollBehavior = 'smooth';
      carousel.scrollTo({ left: offset, behavior: 'smooth' });
      // Actualizar current
      if (rawIndex >= total && rawIndex < total * 2) {
        current = rawIndex - total;
      } else if (rawIndex >= total * 2) {
        current = rawIndex - total * 2;
      } else {
        current = rawIndex % total;
      }
      updateUI();
    }
  });
  
  window.addEventListener('mousemove', e => {
    if (!isDragging) return;
    e.preventDefault();
    carousel.scrollLeft = startScroll - (e.pageX - startX);
  });
  
  updateUI();
  </script>