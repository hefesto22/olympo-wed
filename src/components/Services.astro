---
// src/components/Services.astro
---

<section class="section svc-section" id="servicios">
    <div class="container">
      <div class="svc-header">
        <div>
          <p class="label-tag">Servicios</p>
          <h2 class="section-h2">Todo lo que necesitas<br/>en un solo equipo.</h2>
        </div>
        <div class="svc-nav">
          <button class="svc-nav-btn" id="svc-prev" aria-label="Anterior">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="svc-nav-btn" id="svc-next" aria-label="Siguiente">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  
    <!-- Carrusel — full width con overflow -->
    <div class="svc-carousel-wrapper">
      <div class="svc-carousel" id="svc-carousel">
  
        <!-- 01 Software a Medida -->
        <div class="svc-card">
          <div class="svc-card-top">
            <div class="svc-card-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <rect x="1.5" y="1.5" width="17" height="17" rx="3.5" stroke="currentColor" stroke-width="1.4"/>
                <path d="M6 7l-3 3 3 3M14 7l3 3-3 3M12 5l-4 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="svc-card-title">Software a Medida</h3>
            <button class="svc-card-arrow" aria-label="Ver detalles del servicio">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <p class="svc-card-desc">Tu operación en código. POS, ERP y CRM construidos desde cero — sin plantillas. Código que crece contigo y te pertenece desde el día uno.</p>
          <div class="svc-card-preview svc-preview-code">
            <div class="code-window">
              <div class="code-bar">
                <span class="code-dot"></span><span class="code-dot"></span><span class="code-dot"></span>
                <span class="code-filename">pos.controller.ts</span>
              </div>
              <div class="code-body">
                <div class="code-line"><span class="code-ln">1</span><span class="c-purple">import</span> <span class="c-white">&#123; Controller, Get &#125;</span> <span class="c-purple">from</span> <span class="c-gold">'@nestjs/common'</span></div>
                <div class="code-line"><span class="code-ln">2</span><span class="c-purple">import</span> <span class="c-white">&#123; VentasService &#125;</span> <span class="c-purple">from</span> <span class="c-gold">'./ventas.service'</span></div>
                <div class="code-line"><span class="code-ln">3</span>&nbsp;</div>
                <div class="code-line"><span class="code-ln">4</span><span class="c-blue">@Controller</span><span class="c-white">(</span><span class="c-gold">'ventas'</span><span class="c-white">)</span></div>
                <div class="code-line"><span class="code-ln">5</span><span class="c-purple">export class</span> <span class="c-blue">VentasController</span> <span class="c-white">&#123;</span></div>
                <div class="code-line"><span class="code-ln">6</span>&nbsp;&nbsp;<span class="c-purple">constructor</span><span class="c-white">(</span><span class="c-purple">private</span> <span class="c-white">ventas:</span> <span class="c-blue">VentasService</span><span class="c-white">) &#123;&#125;</span></div>
                <div class="code-line"><span class="code-ln">7</span>&nbsp;</div>
                <div class="code-line"><span class="code-ln">8</span>&nbsp;&nbsp;<span class="c-blue">@Get</span><span class="c-white">(</span><span class="c-gold">'resumen-hoy'</span><span class="c-white">)</span></div>
                <div class="code-line"><span class="code-ln">9</span>&nbsp;&nbsp;<span class="c-purple">async</span> <span class="c-green">resumenHoy</span><span class="c-white">() &#123;</span></div>
                <div class="code-line"><span class="code-ln">10</span>&nbsp;&nbsp;&nbsp;&nbsp;<span class="c-purple">return</span> <span class="c-white">this.ventas.</span><span class="c-green">resumenDiario</span><span class="c-white">(&#123; isv: </span><span class="c-gold">0.15</span> <span class="c-white">&#125;)</span></div>
                <div class="code-line"><span class="code-ln">11</span>&nbsp;&nbsp;<span class="c-white">&#125;</span></div>
                <div class="code-line"><span class="code-ln">12</span><span class="c-white">&#125;</span></div>
              </div>
              <div class="code-status">
                <span class="cs-branch">⎇ main</span>
                <span>TypeScript</span>
                <span class="cs-ok">✓ Prettier</span>
                <span class="cs-right">Ln 10, Col 42</span>
              </div>
            </div>
          </div>
          <div class="svc-card-chips">
            <span>Laravel</span><span>React</span><span>Node.js</span><span>PostgreSQL</span><span>Docker</span>
          </div>
        </div>
  
        <!-- 02 Apps Móviles -->
        <div class="svc-card">
          <div class="svc-card-top">
            <div class="svc-card-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <rect x="5.5" y="1.5" width="9" height="17" rx="2.5" stroke="currentColor" stroke-width="1.4"/>
                <circle cx="10" cy="15.5" r="0.8" fill="currentColor"/>
                <path d="M8.5 4h3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="svc-card-title">Apps Móviles</h3>
            <button class="svc-card-arrow" aria-label="Ver detalles del servicio">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <p class="svc-card-desc">De la idea a la App Store. Apps nativas y multiplataforma que tus clientes van a querer usar. Diseño, desarrollo y publicación en un solo equipo.</p>
          <div class="svc-card-preview svc-preview-mobile">
            <div class="phone-frame">
              <div class="phone-screen">
                <div class="phone-bar">
                  <span class="phone-time">9:41</span>
                  <div class="phone-icons">
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M1 7l2-4 2 3 1.5-2 2.5 3" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                </div>
                <div class="phone-content">
                  <div class="phone-card">
                    <div class="phone-label">Ventas hoy</div>
                    <div class="phone-amount">L 12,480</div>
                    <div class="phone-up">↑ 8% vs ayer</div>
                  </div>
                  <div class="phone-chart">
                    {[35,55,40,70,50,85,65].map(h => (
                      <span class="ph-bar" style={`height:${h}%`}></span>
                    ))}
                  </div>
                  <div class="phone-list">
                    <div class="phone-item"><span class="phone-dot gold"></span><span class="pi-name">Pedido #142</span><span class="pi-time">10:42</span><span class="pi-amt">L 840</span></div>
                    <div class="phone-item"><span class="phone-dot green"></span><span class="pi-name">Pedido #141</span><span class="pi-time">10:37</span><span class="pi-amt">L 320</span></div>
                    <div class="phone-item"><span class="phone-dot gold"></span><span class="pi-name">Pedido #140</span><span class="pi-time">10:31</span><span class="pi-amt">L 1,200</span></div>
                  </div>
                  <div class="phone-tabbar">
                    <svg class="pt-ico pt-on" width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1.5 5L5.5 1.5 9.5 5v4.5h-3v-3h-2v3h-3V5z" stroke="currentColor" stroke-width="1" stroke-linejoin="round"/></svg>
                    <svg class="pt-ico" width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M1.5 9.5V6M5.5 9.5V3M9.5 9.5V1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                    <svg class="pt-ico" width="11" height="11" viewBox="0 0 11 11" fill="none"><circle cx="5.5" cy="3.5" r="2" stroke="currentColor" stroke-width="1"/><path d="M1.5 9.5c0-2 1.8-3 4-3s4 1 4 3" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>
                  </div>
                </div>
              </div>
            </div>
            <div class="phone-frame phone-back">
              <div class="phone-screen phone-screen-back">
                <div class="sk-line sk-w60"></div>
                <div class="sk-block"></div>
                <div class="sk-line"></div>
                <div class="sk-line sk-w80"></div>
                <div class="sk-line sk-w40"></div>
              </div>
            </div>
          </div>
          <div class="svc-card-chips">
            <span>React Native</span><span>Flutter</span><span>iOS</span><span>Android</span>
          </div>
        </div>
  
        <!-- 03 APIs e Integraciones -->
        <div class="svc-card">
          <div class="svc-card-top">
            <div class="svc-card-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <circle cx="4" cy="10" r="2.5" stroke="currentColor" stroke-width="1.4"/>
                <circle cx="16" cy="4" r="2.5" stroke="currentColor" stroke-width="1.4"/>
                <circle cx="16" cy="16" r="2.5" stroke="currentColor" stroke-width="1.4"/>
                <path d="M6.5 10h4m0 0V6m0 4v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="svc-card-title">APIs e Integraciones</h3>
            <button class="svc-card-arrow" aria-label="Ver detalles del servicio">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <p class="svc-card-desc">Tus sistemas hablando entre sí. Conectamos pasarelas de pago, ERPs y servicios externos en flujos confiables. Sin datos perdidos, sin procesos manuales.</p>
          <div class="svc-card-preview svc-preview-api">
            <div class="api-flow">
              <div class="api-node api-node-main">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1" y="1" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.2"/></svg>
                Tu Sistema
              </div>
              <div class="api-connector">
                <div class="api-line"></div>
                <div class="api-pulse"></div>
                <span class="api-badge">REST</span>
              </div>
              <div class="api-nodes-col">
                <div class="api-node api-node-sm">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.1"/><path d="M6 3.5V6l1.5 1.5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
                  Stripe
                </div>
                <div class="api-node api-node-sm">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x="1" y="1" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.1"/><path d="M3.5 6h5M6 3.5v5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>
                  SAP ERP
                </div>
                <div class="api-node api-node-sm">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 8.5L4 3l2.5 4 1.5-2L10 8.5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Analytics
                </div>
              </div>
            </div>
            <div class="api-metrics">
              <span>Requests hoy <b>18,342</b></span>
              <span>p95 <b>89ms</b></span>
              <span>Errores <b class="am-ok">0.2%</b></span>
            </div>
            <div class="api-log">
              <div class="log-line"><span class="log-t">10:42:01</span><span class="log-ok">200</span> POST /api/payments<span class="log-ms">142ms</span></div>
              <div class="log-line"><span class="log-t">10:42:07</span><span class="log-ok">200</span> GET /api/inventory<span class="log-ms">38ms</span></div>
              <div class="log-line"><span class="log-t">10:42:11</span><span class="log-ok">201</span> POST /api/orders<span class="log-ms">96ms</span></div>
              <div class="log-line"><span class="log-t">10:42:15</span><span class="log-warn">429</span> POST /api/sms<span class="log-ms">retry ↻</span></div>
              <div class="log-line"><span class="log-t">10:42:16</span><span class="log-ok">200</span> POST /api/sms<span class="log-ms">81ms</span></div>
              <div class="log-line log-dim"><span class="log-t">10:42:20</span><span class="log-pending">···</span> Webhook ERP<span class="log-ms">en cola</span></div>
            </div>
          </div>
          <div class="svc-card-chips">
            <span>REST</span><span>GraphQL</span><span>Webhooks</span><span>OAuth</span>
          </div>
        </div>
  
        <!-- 04 Automatizaciones -->
        <div class="svc-card">
          <div class="svc-card-top">
            <div class="svc-card-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M4 10a6 6 0 0 1 6-6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                <path d="M16 10a6 6 0 0 1-6 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                <path d="M10 4l2 2-2 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10 16l-2-2 2-2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="svc-card-title">Automatizaciones N8N</h3>
            <button class="svc-card-arrow" aria-label="Ver detalles del servicio">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <p class="svc-card-desc">Tu equipo libre del trabajo repetitivo. Flujos automáticos que conectan herramientas, eliminan errores humanos y ejecutan tareas mientras duermes.</p>
          <div class="svc-card-preview svc-preview-automation">
            <div class="auto-top">
            <div class="flow-nodes">
              <div class="flow-node flow-trigger">
                <span class="flow-icon">⚡</span>
                <span>Trigger</span>
              </div>
              <div class="flow-arrow-down"></div>
              <div class="flow-row">
                <div class="flow-node flow-action">
                  <span class="flow-icon">📧</span>
                  <span>Email</span>
                </div>
                <div class="flow-node flow-action">
                  <span class="flow-icon">📊</span>
                  <span>Sheet</span>
                </div>
                <div class="flow-node flow-action">
                  <span class="flow-icon">💬</span>
                  <span>Slack</span>
                </div>
              </div>
              <div class="flow-arrow-down"></div>
              <div class="flow-node flow-done">
                <span class="flow-icon">✓</span>
                <span>Completado</span>
              </div>
            </div>
            <div class="flow-stats">
              <div class="flow-stat">
                <span class="flow-stat-val">2,840</span>
                <span class="flow-stat-label">ejecuciones/mes</span>
              </div>
              <div class="flow-stat">
                <span class="flow-stat-val">98%</span>
                <span class="flow-stat-label">sin errores</span>
              </div>
              <div class="flow-stat">
                <span class="flow-stat-val">64h</span>
                <span class="flow-stat-label">ahorradas/mes</span>
              </div>
            </div>
            </div>
            <div class="auto-log">
              <div class="al-row"><span class="al-ok">✓</span><span class="al-t">10:41</span><span class="al-name">Factura #4821 → email + PDF</span><span class="al-ms">1.2s</span></div>
              <div class="al-row"><span class="al-ok">✓</span><span class="al-t">10:38</span><span class="al-name">Lead nuevo → CRM + Slack</span><span class="al-ms">0.8s</span></div>
              <div class="al-row"><span class="al-ok">✓</span><span class="al-t">10:31</span><span class="al-name">Stock bajo → orden de compra</span><span class="al-ms">2.1s</span></div>
            </div>
          </div>
          <div class="svc-card-chips">
            <span>N8N</span><span>Make</span><span>Zapier</span><span>Scripts</span>
          </div>
        </div>
  
        <!-- 05 Infraestructura -->
        <div class="svc-card">
          <div class="svc-card-top">
            <div class="svc-card-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <rect x="1.5" y="3.5" width="17" height="4.5" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                <rect x="1.5" y="12" width="17" height="4.5" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                <circle cx="15.5" cy="5.75" r="0.9" fill="currentColor"/>
                <circle cx="15.5" cy="14.25" r="0.9" fill="currentColor"/>
                <circle cx="13" cy="5.75" r="0.9" fill="currentColor"/>
                <circle cx="13" cy="14.25" r="0.9" fill="currentColor"/>
              </svg>
            </div>
            <h3 class="svc-card-title">Infraestructura</h3>
            <button class="svc-card-arrow" aria-label="Ver detalles del servicio">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <p class="svc-card-desc">Tu negocio no puede darse el lujo de caerse. Configuramos servidores locales y cloud con monitoreo, backups automáticos y uptime como prioridad.</p>
          <div class="svc-card-preview svc-preview-infra">
            <div class="infra-host">
              <span class="ih-name">srv-olympo-01</span>
              <span class="ih-os">Ubuntu 22.04 LTS · monitoreo 24/7</span>
            </div>
            <div class="infra-monitor">
              <div class="infra-row">
                <span class="infra-label">CPU</span>
                <div class="infra-bar-track"><div class="infra-bar" style="width:34%"></div></div>
                <span class="infra-val">34%</span>
              </div>
              <div class="infra-row">
                <span class="infra-label">RAM</span>
                <div class="infra-bar-track"><div class="infra-bar" style="width:61%"></div></div>
                <span class="infra-val">61%</span>
              </div>
              <div class="infra-row">
                <span class="infra-label">DISK</span>
                <div class="infra-bar-track"><div class="infra-bar" style="width:48%"></div></div>
                <span class="infra-val">48%</span>
              </div>
              <div class="infra-row">
                <span class="infra-label">NET</span>
                <div class="infra-bar-track"><div class="infra-bar infra-bar-green" style="width:22%"></div></div>
                <span class="infra-val">22%</span>
              </div>
            </div>
            <div class="infra-status">
              <div class="infra-status-row">
                <span class="status-dot green"></span>
                <span>nginx — activo</span>
              </div>
              <div class="infra-status-row">
                <span class="status-dot green"></span>
                <span>postgres — activo</span>
              </div>
              <div class="infra-status-row">
                <span class="status-dot green"></span>
                <span>backup diario — 02:00 AM</span>
              </div>
              <div class="infra-status-row">
                <span class="status-dot green"></span>
                <span>ssl — renueva en 68 días</span>
              </div>
              <div class="infra-uptime">
                <span class="uptime-label">UPTIME — 30 DÍAS</span>
                <span class="uptime-val">99.97%</span>
              </div>
              <div class="uptime-ticks">
                {Array.from({ length: 30 }).map((_, i) => (
                  <span class={`ut ${i === 21 ? 'ut-warn' : ''}`}></span>
                ))}
              </div>
              <div class="ut-caption"><span>hace 30 días</span><span>hoy</span></div>
            </div>
          </div>
          <div class="svc-card-chips">
            <span>Linux</span><span>Docker</span><span>Nginx</span><span>VPS</span>
          </div>
        </div>
  
        <!-- 06 Consultoría IT -->
        <div class="svc-card">
          <div class="svc-card-top">
            <div class="svc-card-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <circle cx="10" cy="10" r="8.5" stroke="currentColor" stroke-width="1.4"/>
                <path d="M10 6.5v4.5l3 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="svc-card-title">Consultoría IT</h3>
            <button class="svc-card-arrow" aria-label="Ver detalles del servicio">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <p class="svc-card-desc">Claridad técnica para decisiones de negocio. Auditamos tus sistemas, identificamos cuellos de botella y diseñamos un roadmap técnico con sentido real.</p>
          <div class="svc-card-preview svc-preview-consult">
            <div class="roadmap">
              <div class="roadmap-item roadmap-done">
                <div class="roadmap-dot done"></div>
                <div class="roadmap-content">
                  <span class="roadmap-phase">Fase 1</span>
                  <span class="roadmap-name">Auditoría de sistemas</span>
                  <span class="roadmap-sub">14 sistemas · 3 hallazgos críticos</span>
                </div>
                <span class="roadmap-tag done-tag">✓ Listo</span>
              </div>
              <div class="roadmap-line"></div>
              <div class="roadmap-item roadmap-active">
                <div class="roadmap-dot active"></div>
                <div class="roadmap-content">
