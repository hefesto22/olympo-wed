  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes bar-grow {
    from { transform: scaleY(0); }
    to   { transform: scaleY(1); }
  }
  </style>
  
  <script>
  // ── Tab switching ──────────────────────────────
  const tabs   = document.querySelectorAll<HTMLButtonElement>('.ps-btn');
  const panels = document.querySelectorAll<HTMLElement>('.tab-panel');
  
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach(t => t.classList.remove('ps-active'));
      tab.classList.add('ps-active');
      panels.forEach(p => p.classList.remove('tab-active'));
      document.querySelector<HTMLElement>(`[data-panel="${target}"]`)?.classList.add('tab-active');
    });
  });
  
  // ── Animated counters ──────────────────────────
  const counter = (el: HTMLElement, target: number) => {
    let start = 0;
    const step = (ts: number) => {
      if (!start) start = ts;
      const p = Math.min((ts - start) / 1600, 1);
      el.textContent = Math.floor((1 - Math.pow(1 - p, 4)) * target).toString();
      if (p < 1) requestAnimationFrame(step);
      else el.textContent = target.toString();
    };
    requestAnimationFrame(step);
  };
  
  let triggered = false;
  const statsEl = document.querySelector('.hero-stats');
  if (statsEl) {
    new IntersectionObserver(([e]) => {
      if (e.isIntersecting && !triggered) {
        triggered = true;
        document.querySelectorAll<HTMLElement>('.stat-val').forEach(el =>
          counter(el, parseInt(el.dataset.count || '0'))
        );
      }
    }, { threshold: 0.4 }).observe(statsEl);
  }
  
  // ── Subtle card tilt on mouse move ────────────
  const card   = document.querySelector<HTMLElement>('.preview-card');
  const visual = document.querySelector<HTMLElement>('.hero-visual');
  if (card && visual) {
    visual.addEventListener('mousemove', (e) => {
      const rect = visual.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width  - 0.5;
      const y = (e.clientY - rect.top)  / rect.height - 0.5;
      card.style.transform = `perspective(1000px) rotateY(${x * 8}deg) rotateX(${-y * 5}deg)`;
    });
    visual.addEventListener('mouseleave', () => {
      card.style.transform = 'perspective(1000px) rotateY(-3deg) rotateX(2deg)';
    });
  }
  </script>