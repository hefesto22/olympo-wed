---
// src/components/Hero.astro
---

<section class="hero">

    <!-- Ambient background layers -->
    <div class="hero-bg" aria-hidden="true">
      <div class="bg-glow bg-glow-1"></div>
      <div class="bg-glow bg-glow-2"></div>
      <div class="bg-glow bg-glow-3"></div>
      <div class="bg-grid"></div>
      <div class="bg-noise"></div>
    </div>
  
    <div class="hero-container">
  
      <!-- LEFT: copy -->
      <div class="hero-copy">
  
        <div class="copy-eyebrow">
          <span class="eyebrow-line"></span>
          <span class="eyebrow-text">Desarrollo de Software · Santa Rosa de Copán, Honduras</span>
        </div>
  
        <h1 class="hero-heading">
          <span class="h-line h-line-1">Detrás de cada negocio</span>
          <span class="h-line h-line-2">que escala, hay</span>
          <span class="h-line h-line-3"><span class="h-em">tecnología que funciona.</span></span>
        </h1>
  
        <p class="hero-sub">
          Empresa de desarrollo de software en Honduras. Construimos sistemas a medida,
          apps móviles, POS, ERP, CRM y automatizaciones para negocios que necesitan crecer.
        </p>
  
        <div class="hero-actions">
          <a href="/contacto" class="btn-primary">
            Iniciar proyecto
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/portafolio" class="btn-ghost">Ver portafolio</a>
        </div>
  
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-val" data-count="50">0</span><span class="stat-suf">+</span>
            <span class="stat-label">proyectos</span>
          </div>
          <div class="stat-sep"></div>
          <div class="stat">
            <span class="stat-val" data-count="5">0</span><span class="stat-suf">+</span>
            <span class="stat-label">años</span>
          </div>
          <div class="stat-sep"></div>
          <div class="stat">
            <span class="stat-val" data-count="100">0</span><span class="stat-suf">%</span>
            <span class="stat-label">satisfechos</span>
          </div>
        </div>
  
      </div>
  
      <!-- RIGHT: preview card -->
      <div class="hero-visual">
        <div class="visual-aura"></div>
  
        <div class="preview-card">
          <div class="preview-glow-top"></div>
  
          <!-- Window chrome -->
          <div class="preview-bar">
            <div class="preview-dots">
              <span class="dot dot-red"></span>
              <span class="dot dot-yellow"></span>
              <span class="dot dot-green"></span>
            </div>
            <div class="preview-title-bar">olympo — sistema POS</div>
            <div class="preview-live">
              <span class="live-dot"></span>
              en producción
            </div>
          </div>
  
          <!-- App body -->
          <div class="preview-body">
  
            <nav class="preview-sidebar">
              <button class="ps-btn ps-active" data-tab="venta">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M1 1.5h1.6l1.2 7h6.4l1.3-5H4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="5" cy="11" r="1" fill="currentColor"/><circle cx="9.5" cy="11" r="1" fill="currentColor"/></svg>
                Venta
              </button>
              <button class="ps-btn" data-tab="dashboard">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><rect x="1" y="1" width="11" height="11" rx="2" stroke="currentColor" stroke-width="1.2"/><path d="M3.5 6.5h6M3.5 4h3M3.5 9h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                Dashboard
              </button>
              <button class="ps-btn" data-tab="inventario">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M6.5 1.5L11.5 4.2v4.6L6.5 11.5 1.5 8.8V4.2L6.5 1.5z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
                Inventario
              </button>
              <button class="ps-btn" data-tab="ventas">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M1.5 9.5L4 5l3 4 2-2.5 2.5 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Ventas
              </button>
              <button class="ps-btn" data-tab="reportes">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><rect x="2" y="4" width="9" height="7" rx="1.2" stroke="currentColor" stroke-width="1.2"/><path d="M4.5 4V3a2 2 0 014 0v1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                Reportes
              </button>
            </nav>
  
            <main class="preview-main">

              <!-- Venta (POS) panel — grid de productos + carrito -->
              <div class="tab-panel tab-active" data-panel="venta">
                <div class="pos-layout">
                  <div class="pos-products">
                    <div class="pos-cats">
                      <span class="cat-chip cat-on">Todos</span>
                      <span class="cat-chip">Equipos</span>
                      <span class="cat-chip">Accesorios</span>
                    </div>
                    <div class="prod-grid">
                      {[
                        { name: 'Laptop Dell XPS 13', price: 'L 28,500', stock: 12, qty: 1 },
                        { name: 'Monitor LG 27"',     price: 'L 6,900',  stock: 5,  qty: 0 },
                        { name: 'Teclado Mec. K2',    price: 'L 2,400',  stock: 28, qty: 0 },
                        { name: 'Mouse Logitech MX',  price: 'L 1,850',  stock: 3,  qty: 2 },
                        { name: 'Hub USB-C 7 en 1',   price: 'L 1,150',  stock: 17, qty: 1 },
                        { name: 'Audífonos JBL',      price: 'L 990',    stock: 9,  qty: 0 },
                      ].map(p => (
                        <div class={`prod-tile ${p.qty > 0 ? 'pt-sel' : ''}`}>
                          {p.qty > 0 && <span class="pt-badge">×{p.qty}</span>}
                          <span class="pt-name">{p.name}</span>
                          <div class="pt-row">
                            <span class="pt-price">{p.price}</span>
                            <span class="pt-stock">{p.stock} disp.</span>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                  <aside class="pos-ticket">
                    <div class="ticket-head">
                      <span class="th-id">#000482</span>
                      <span>Caja 1 · 10:42</span>
                    </div>
                    <div class="ticket-client">Cliente — Consumidor final</div>
                    <div class="ticket-lines">
                      {[
                        { qty: 1, name: 'Laptop Dell XPS', price: '28,500.00' },
                        { qty: 2, name: 'Mouse MX',        price: '3,700.00'  },
                        { qty: 1, name: 'Hub USB-C',       price: '1,150.00'  },
                      ].map(l => (
                        <div class="t-line">
                          <span class="tl-qty">{l.qty}×</span>
                          <span class="tl-name">{l.name}</span>
                          <span class="tl-price">{l.price}</span>
                        </div>
                      ))}
                    </div>
                    <div class="ticket-totals">
                      <div class="tt-row"><span>Subtotal</span><span>33,350.00</span></div>
                      <div class="tt-row"><span>ISV 15%</span><span>5,002.50</span></div>
                      <div class="tt-row tt-total"><span>Total</span><span>L 38,352.50</span></div>
                    </div>
                    <div class="ticket-methods">
                      <span class="tm-chip tm-on">Efectivo</span>
                      <span class="tm-chip">Tarjeta</span>
                      <span class="tm-chip">Transf.</span>
                    </div>
                    <span class="ticket-pay">Cobrar →</span>
                  </aside>
                </div>
              </div>

              <!-- Dashboard panel -->
              <div class="tab-panel" data-panel="dashboard">
                <div class="dash-kpis">
                  {[
                    { l: 'Ventas hoy',   v: 'L 84,320', d: '↑ 12%', up: true },
                    { l: 'Órdenes',      v: '142',      d: '↑ 9%',  up: true },
                    { l: 'Ticket prom.', v: 'L 594',    d: '↑ 4%',  up: true },
                    { l: 'Margen',       v: '42%',      d: '↓ 1%',  up: false },
                  ].map(k => (
                    <div class="dk-card">
                      <span class="dk-l">{k.l}</span>
                      <span class="dk-v">{k.v}</span>
                      <span class={`dk-d ${k.up ? 'dk-up' : 'dk-dn'}`}>{k.d}</span>
                    </div>
                  ))}
                </div>
                <div class="pm-chart">
                  <div class="chart-bars">
                    {[40,65,45,80,55,90,70,95,60,85,75,100].map((h, i) => (
                      <div class="c-bar" style={`height:${h}%;animation-delay:${i*55}ms`}></div>
                    ))}
                  </div>
                  <div class="chart-x">
                    <span>8am</span><span>10am</span><span>12pm</span><span>2pm</span><span>4pm</span><span>6pm</span>
                  </div>
                </div>
                <div class="dash-goal">
                  <div class="goal-top">
                    <span>Meta del día</span>
                    <span>84% — L 84,320 / L 100,000</span>
                  </div>
                  <div class="goal-track"><div class="goal-fill" style="width:84%"></div></div>
                </div>
              </div>
  
              <!-- Inventario panel -->
              <div class="tab-panel" data-panel="inventario">
                <div class="pm-head">
                  <div>
                    <p class="pm-label">Stock actual</p>
                    <p class="pm-val">1,284 items</p>
                  </div>
                  <span class="badge-warn">⚠ 6 bajo mínimo</span>
                </div>
                <div class="tbl tbl-inv">
                  <div class="tbl-h"><span>Producto</span><span>SKU</span><span>Stock</span><span>Estado</span></div>
                  {[
                    { name: 'Laptop Dell XPS 13',  sku: 'LP-0034', stock: 12, st: 'OK',      cls: 'pill-ok'   },
                    { name: 'Monitor LG 27"',      sku: 'MN-0108', stock: 5,  st: 'Bajo',    cls: 'pill-low'  },
                    { name: 'Teclado Mecánico K2', sku: 'TC-0219', stock: 28, st: 'OK',      cls: 'pill-ok'   },
                    { name: 'Mouse Logitech MX',   sku: 'MS-0075', stock: 3,  st: 'Crítico', cls: 'pill-crit' },
                    { name: 'Hub USB-C 7 en 1',    sku: 'AC-0311', stock: 17, st: 'OK',      cls: 'pill-ok'   },
                  ].map(r => (
                    <div class="tbl-r">
                      <span class="td-name">{r.name}</span>
                      <span class="td-mono">{r.sku}</span>
                      <span class="td-num">{r.stock}</span>
                      <span class={`pill ${r.cls}`}>{r.st}</span>
                    </div>
                  ))}
                </div>
                <p class="tbl-note">Valor de inventario — L 1,842,300</p>
              </div>
  
              <!-- Ventas panel -->
              <div class="tab-panel" data-panel="ventas">
                <div class="pm-head">
                  <div>
                    <p class="pm-label">Ventas del mes</p>
                    <p class="pm-val">L 1,240,800</p>
                  </div>
                  <span class="badge-up">↑ 8% vs anterior</span>
                </div>
                <div class="tbl tbl-sales">
                  <div class="tbl-h"><span>Factura</span><span>Hora</span><span>Método</span><span>Total</span></div>
                  {[
                    { f: '#000481', h: '10:42', m: 'Tarjeta',   cls: 'pill-gold', t: 'L 1,240.00' },
                    { f: '#000480', h: '10:37', m: 'Efectivo',  cls: 'pill-ok',   t: 'L 386.00'   },
                    { f: '#000479', h: '10:21', m: 'Transfer.', cls: 'pill-blue', t: 'L 7,900.00' },
                    { f: '#000478', h: '09:58', m: 'Tarjeta',   cls: 'pill-gold', t: 'L 2,150.00' },
                    { f: '#000477', h: '09:45', m: 'Efectivo',  cls: 'pill-ok',   t: 'L 594.00'   },
                  ].map(r => (
                    <div class="tbl-r">
                      <span class="td-mono">{r.f}</span>
                      <span class="td-mono">{r.h}</span>
                      <span class={`pill ${r.cls}`}>{r.m}</span>
                      <span class="td-num">{r.t}</span>
                    </div>
                  ))}
                </div>
                <p class="tbl-note">Mostrando 5 de 3,412 transacciones</p>
              </div>
  
              <!-- Reportes panel -->
              <div class="tab-panel" data-panel="reportes">
                <div class="pm-head">
                  <div>
                    <p class="pm-label">Resumen trimestral</p>
                    <p class="pm-val">Q1 — 2025</p>
                  </div>
                  <span class="badge-up">↑ 23% YoY</span>
                </div>
                <div class="tbl tbl-rep">
                  <div class="tbl-h"><span>Concepto</span><span>Q4 24</span><span>Q1 25</span><span>Δ</span></div>
                  {[
                    { c: 'Ingresos totales', a: 'L 3,124,900', b: 'L 3,842,400', d: '+23%'  },
                    { c: 'Costo de ventas',  a: 'L 1,684,300', b: 'L 1,921,200', d: '+14%'  },
                    { c: 'Margen bruto',     a: '46%',         b: '50%',         d: '+4 pt' },
                    { c: 'Ticket promedio',  a: 'L 512',       b: 'L 594',       d: '+16%'  },
                    { c: 'Clientes activos', a: '282',         b: '318',         d: '+13%'  },
                  ].map(r => (
                    <div class="tbl-r">
                      <span class="td-name">{r.c}</span>
                      <span class="td-num td-dim">{r.a}</span>
                      <span class="td-num">{r.b}</span>
                      <span class="delta-up">{r.d}</span>
                    </div>
                  ))}
                </div>
                <div class="rep-actions">
                  <span class="rep-btn">Exportar PDF</span>
                  <span class="rep-btn">Excel</span>
                </div>
              </div>
  
            </main>
          </div>
        </div>
      </div>
  
    </div>
  </section>
  
  <style>
  /* ─── Base ─────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: 56px;
    background: var(--bg);
    min-height: 100svh;
    display: flex;
    align-items: center;
  }
  
  /* ─── Background ───────────────────────────────── */
  .hero-bg { position: absolute; inset: 0; pointer-events: none; z-index: 0; }
  
  .bg-glow { position: absolute; border-radius: 50%; filter: blur(120px); }
  .bg-glow-1 {
    width: 700px; height: 700px; top: -200px; left: -150px;
    background: radial-gradient(circle, rgba(200,169,110,0.07) 0%, transparent 65%);
    animation: glow-drift-1 14s ease-in-out infinite;
  }
  .bg-glow-2 {
    width: 500px; height: 500px; bottom: -100px; right: -80px;
    background: radial-gradient(circle, rgba(200,169,110,0.05) 0%, transparent 65%);
    animation: glow-drift-2 18s ease-in-out infinite;
  }
  .bg-glow-3 {
    width: 350px; height: 350px; top: 40%; right: 30%;
    background: radial-gradient(circle, rgba(200,169,110,0.03) 0%, transparent 70%);
    animation: glow-drift-1 22s ease-in-out infinite reverse;
  }
  @keyframes glow-drift-1 {
    0%,100% { transform: translate(0,0) scale(1); }
    33%     { transform: translate(40px,-30px) scale(1.05); }
    66%     { transform: translate(-20px,20px) scale(0.95); }
  }
  @keyframes glow-drift-2 {
    0%,100% { transform: translate(0,0) scale(1); }
    50%     { transform: translate(-30px,-40px) scale(1.08); }
  }
  
  .bg-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 52px 52px;
    mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black 20%, transparent 100%);
  }
  .bg-noise {
    position: absolute; inset: 0; opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }
  
  /* ─── Layout ───────────────────────────────────── */
  .hero-container {
    position: relative; z-index: 3;
    width: 100%; max-width: 1280px;
    margin: 0 auto;
    padding: 5rem 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 900px) {
    .hero-container { grid-template-columns: 1fr; gap: 3rem; padding: 4rem 1.5rem; text-align: center; }
  }
  
  /* ─── LEFT copy ────────────────────────────────── */
  .hero-copy { display: flex; flex-direction: column; align-items: flex-start; }
  @media (max-width: 900px) { .hero-copy { align-items: center; } }
  
  .copy-eyebrow {
    display: flex; align-items: center; gap: 0.75rem;
    margin-bottom: 1.75rem;
    opacity: 0; animation: fadeUp 0.5s 0.1s forwards;
  }
  .eyebrow-line {
    display: block; width: 24px; height: 1px;
    background: var(--gold); flex-shrink: 0;
  }
  .eyebrow-text {
    font-size: 0.65rem; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gold);
    font-family: var(--font-mono);
  }
  
  .hero-heading {
    display: flex; flex-direction: column;
    font-size: clamp(2.8rem, 5.5vw, 5rem);
    font-weight: 800; line-height: 1.0;
    letter-spacing: -0.05em; margin-bottom: 1.75rem;
  }
  .h-line { display: block; color: var(--text-1); opacity: 0; }
  .h-line-1 { animation: fadeUp 0.7s 0.2s forwards; }
  .h-line-2 { animation: fadeUp 0.7s 0.32s forwards; }

  /* Gold italic text — background-clip:text MUST stay isolated */
  .h-em {
    background: linear-gradient(118deg, #f5de8a 0%, #c8a040 28%, #e8b860 55%, #8a5c1e 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  .h-line-3 { animation: fadeUp 0.7s 0.44s ease forwards; }
  
  .hero-sub {
    font-size: clamp(0.9rem, 1.6vw, 1.02rem); color: var(--text-2);
    line-height: 1.85; max-width: 420px; font-weight: 300;
    margin-bottom: 2.5rem;
    opacity: 0; animation: fadeUp 0.7s 0.56s forwards;
  }
  
  .hero-actions {
    display: flex; gap: 0.75rem; flex-wrap: wrap;
    margin-bottom: 3rem;
    opacity: 0; animation: fadeUp 0.7s 0.68s forwards;
  }
  
  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1.4rem;
    background: var(--gold); color: #0a0a0a;
    font-size: 0.82rem; font-weight: 700; border-radius: 8px;
    letter-spacing: -0.01em; text-decoration: none;
    transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .btn-primary:hover {
    opacity: 0.92; transform: translateY(-1px);
    box-shadow: 0 8px 28px rgba(200,169,110,0.28);
  }
  
  .btn-ghost {
    display: inline-flex; align-items: center;
    padding: 0.75rem 1.4rem;
    border: 1px solid var(--border); color: var(--text-2);
    font-size: 0.82rem; font-weight: 500; border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .btn-ghost:hover {
    border-color: rgba(200,169,110,0.3);
    color: var(--gold); background: rgba(200,169,110,0.04);
  }
  
  .hero-stats {
    display: flex; align-items: center; gap: 1.75rem;
    opacity: 0; animation: fadeUp 0.7s 0.8s forwards;
  }
  .stat { display: flex; align-items: baseline; gap: 0.1rem; flex-wrap: wrap; }
  .stat-val { font-size: 1.5rem; font-weight: 800; color: var(--text-1); letter-spacing: -0.04em; line-height: 1; }
  .stat-suf { font-size: 0.9rem; color: var(--gold); font-weight: 700; margin-right: 0.35rem; }
  .stat-label { font-size: 0.58rem; color: var(--text-3); letter-spacing: 0.1em; text-transform: uppercase; font-family: var(--font-mono); width: 100%; }
  .stat-sep { width: 1px; height: 28px; background: var(--border); flex-shrink: 0; }
  
  /* ─── RIGHT visual ─────────────────────────────── */
  .hero-visual {
    position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; animation: fadeIn 1s 0.4s forwards;
    overflow: visible;
  }
  
  .visual-aura {
    position: absolute; width: 80%; height: 60%;
    background: radial-gradient(ellipse, rgba(200,169,110,0.14) 0%, transparent 70%);
    filter: blur(40px);
    animation: aura-base 6s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes aura-base {
    0%,100% { opacity: 0.7; transform: scale(1); }
    50%     { opacity: 1;   transform: scale(1.06); }
  }

  /* ─── Preview card ─────────────────────────────── */
  .preview-card {
    position: relative; z-index: 1;
    width: 100%; max-width: 580px;
    border: 1px solid transparent;
    border-radius: 14px;
    background: var(--bg-1);
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.04),
      0 32px 80px rgba(0,0,0,0.55),
      0 0 60px rgba(200,169,110,0.12);
    transform: perspective(1000px) rotateY(-3deg) rotateX(2deg);
    transition: transform 0.6s ease;
    background-clip: padding-box;
  }
  
  @property --angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }
  
  .preview-card::before {
    content: '';
    position: absolute; inset: -1.5px;
    border-radius: 15px; z-index: -1;
    background: conic-gradient(
      from var(--angle, 0deg),
      transparent 20%,
      rgba(200,169,110,0.15) 35%,
      rgba(248,215,109,0.9) 45%,
      rgba(200,169,110,0.8) 50%,
      rgba(248,215,109,0.9) 55%,
      rgba(200,169,110,0.15) 65%,
      transparent 80%
    );
    animation: liquid-border 4s linear infinite;
  }
  .preview-card::after {
    content: '';
    position: absolute; inset: 1px;
    border-radius: 13px; z-index: -1;
    background: var(--bg-1);
  }
